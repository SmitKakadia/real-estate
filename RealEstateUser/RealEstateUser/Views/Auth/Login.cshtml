@model RealEstateUser.Models.LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Lumina Luxe</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* ── Exact Stitch palette ── */
        :root {
            --bg:         #08090d;       /* near-black page bg */
            --card-bg:    #111318;       /* dark card surface  */
            --card-border:#2a2d35;       /* subtle card border */
            --input-bg:   #1a1d24;       /* input fields       */
            --input-border:#2e3240;      /* input border       */
            --input-focus:#c9a227;       /* gold focus ring    */
            --label:      #6b7280;       /* uppercase labels   */
            --text:       #d1d5db;       /* body text          */
            --text-dim:   #4b5563;       /* dimmed/footer text */
            --gold:       #c9a227;       /* Stitch gold        */
            --gold-hover: #b08d1e;       /* gold darker hover  */
            --tab-active: #c9a227;       /* active tab line    */
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg);
            min-height: 100vh;
        }

        /* ── Ambient background glows (iOS glass vibe) ── */
        .up-glow {
            position: fixed;
            width: 40vw;
            height: 40vw;
            border-radius: 50%;
            filter: blur(120px);
            z-index: 0;
            opacity: 0.15;
            pointer-events: none;
        }
        .up-glow-1 { top: -10%; left: -10%; background: var(--gold); }
        .up-glow-2 { bottom: -10%; right: -10%; background: #3b82f6; } /* subtle blue contrast */

        .wrapper { width: 100%; max-width: 420px; position: relative; z-index: 1; }

        /* ── Card area — centers card vertically in remaining space ── */
        .card-area {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 1rem 2rem;  /* 80px top = 60px navbar + 20px gap */
        }

        /* ── Navbar — fixed at top like main layout ── */
        .navbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            height: 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
            background: rgba(8, 9, 13, 0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.5px;
        }
        .brand i { color: var(--gold); font-size: 1.1rem; }
        .nav-home {
            font-size: 0.78rem;
            color: var(--label);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: color 0.2s;
        }
        .nav-home:hover { color: #fff; }

        /* ── Card — heavy frosted glass (iOS glass style) ── */
        .card {
            position: relative;
            z-index: 10;
            background: rgba(17, 19, 24, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15); /* top highlight */
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        /* ── Tab bar ── */
        .tab-bar {
            display: flex;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.03);
        }
        .tab {
            flex: 1;
            padding: 1rem;
            text-align: center;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--label);
            transition: color 0.2s;
            position: relative;
        }
        .tab.active {
            color: var(--gold);
        }
        .tab.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0; right: 0;
            height: 2px;
            background: var(--gold);
            border-radius: 2px 2px 0 0;
        }
        .tab:hover:not(.active) { color: var(--text); }

        /* ── Form body ── */
        .card-body { padding: 2rem 2rem 1.75rem; }

        .field { margin-bottom: 1.25rem; }

        .field label {
            display: block;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);  /* slightly lighter on glass */
            margin-bottom: 0.5rem;
        }

        .input-wrap { position: relative; }

        .input-wrap > i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--label);
            font-size: 0.8rem;
            pointer-events: none;
            transition: color 0.2s;
        }

        .glass-input {
            width: 100%;
            background: rgba(255,255,255,0.06);  /* glass input on glass card */
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            padding: 0.75rem 2.6rem 0.75rem 2.6rem;
            font-size: 0.875rem;
            font-family: 'Poppins', sans-serif;
            color: #f3f4f6;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .glass-input::placeholder { color: rgba(255,255,255,0.25); }
        .glass-input:focus {
            border-color: var(--input-focus);
            box-shadow: 0 0 0 3px rgba(201,162,39,0.18);
        }
        .glass-input:focus ~ i,
        .input-wrap:focus-within > i { color: var(--gold); }

        .toggle-password {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--label);
            font-size: 0.9rem;
            cursor: pointer;
            transition: color 0.2s;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .toggle-password:hover { color: #f3f4f6; }

        /* Autofill */
        input:-webkit-autofill {
            -webkit-box-shadow: 0 0 0px 1000px var(--input-bg) inset !important;
            -webkit-text-fill-color: var(--text) !important;
        }

        /* Forgot link inside password field */
        .forgot-link {
            position: absolute;
            right: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: var(--gold);
            text-decoration: none;
            text-transform: uppercase;
        }
        .forgot-link:hover { text-decoration: underline; }

        /* ── Submit button — Stitch gold ── */
        .btn-submit {
            width: 100%;
            background: var(--gold);
            color: #0a0a0a;
            border: none;
            border-radius: 8px;
            padding: 0.85rem;
            font-size: 0.75rem;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
        }
        .btn-submit:hover {
            background: var(--gold-hover);
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(201,162,39,0.35);
        }

        /* ── Secondary link ── */
        .secondary-link {
            display: block;
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.78rem;
            color: var(--text-dim);
        }
        .secondary-link a {
            color: var(--gold);
            font-weight: 600;
            text-decoration: none;
        }
        .secondary-link a:hover { text-decoration: underline; }

        /* ── Footer links ── */
        .card-footer {
            border-top: 1px solid rgba(255,255,255,0.06);
            padding: 0.9rem 2rem;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            background: rgba(255,255,255,0.02);
        }
        .card-footer a {
            font-size: 0.65rem;
            color: var(--text-dim);
            text-decoration: none;
            letter-spacing: 0.3px;
        }
        .card-footer a:hover { color: var(--text); }

        /* ── Error alert ── */
        .alert-error {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.25);
            color: #f87171;
            border-radius: 8px;
            padding: 0.7rem 1rem;
            font-size: 0.8rem;
            margin-bottom: 1.25rem;
        }

        /* ── Page footer ── */
        .page-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.65rem;
            color: var(--text-dim);
            letter-spacing: 0.3px;
        }
    </style>
</head>
<body>
    <!-- Ambient glows -->
    <div class="up-glow up-glow-1"></div>
    <div class="up-glow up-glow-2"></div>

    <!-- ══ Fixed Navbar ══ -->
    <nav class="navbar">
        <div class="brand">
            <i class="fa-solid fa-leaf"></i>
            Lumina Luxe
        </div>
        <a asp-action="Index" asp-controller="Home" class="nav-home">
            <i class="fa-solid fa-house" style="font-size:0.7rem;"></i> Home
        </a>
    </nav>

    <!-- ══ Card centered in remaining viewport ══ -->
    <div class="card-area">
        <div class="wrapper">

            <!-- Card -->
            <div class="card">

                <!-- Tab Bar -->
                <div class="tab-bar">
                    <span class="tab active">Login</span>
                    <a asp-action="Register" class="tab">Register</a>
                </div>

                <div class="card-body">

                    @* ✅ MANDATORY: ViewBag.ErrorMessage *@
                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
                    {
                    <div class="alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>@ViewBag.ErrorMessage</span>
                    </div>
                }

                @* ✅ MANDATORY: form asp-action="Login" method="post" *@
                <form asp-action="Login" method="post">

                    <!-- Email -->
                    <div class="field">
                        <label>Email or Username</label>
                        <div class="input-wrap">
                            @* ✅ MANDATORY: asp-for="Email" *@
                            <input asp-for="Email"
                                   type="email"
                                   class="glass-input"
                                   placeholder="Enter your credentials"
                                   required />
                            <i class="fa-regular fa-user"></i>
                        </div>
                        <span asp-validation-for="Email" class="val-error" style="display:block;margin-top:0.3rem;font-size:0.7rem;color:#f87171;"></span>
                    </div>

                    <!-- Password -->
                    <div class="field">
                        <label>Password</label>
                        <div class="input-wrap">
                            @* ✅ MANDATORY: asp-for="Password" *@
                            <input asp-for="Password"
                                   type="password"
                                   id="loginPassword"
                                   class="glass-input"
                                   placeholder="••••••••"
                                   required />
                            <i class="fa-solid fa-lock"></i>
                            <button type="button" class="toggle-password" onclick="togglePasswordVisibility('loginPassword', this)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="val-error" style="display:block;margin-top:0.3rem;font-size:0.7rem;color:#f87171;"></span>
                        <div style="text-align: right; margin-top: 0.5rem;">
                            <a href="#" class="forgot-link" style="position:static; transform:none;">Forgot?</a>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">Sign In</button>

                </form>

                <p class="secondary-link">
                    Don't have an account?
                    @* ✅ MANDATORY: asp-action="Register" *@
                    <a asp-action="Register">Create account</a>
                </p>

            </div><!-- /card-body -->

            <div class="card-footer">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Contact Support</a>
            </div>

        </div><!-- /card -->

        </div><!-- /wrapper -->
    </div><!-- /card-area -->

    <!-- Toast Notification -->
    <div id="toastNotification" style="position:fixed; top:20px; right:20px; background:rgba(34,197,94,0.15); border:1px solid rgba(34,197,94,0.4); border-radius:8px; padding:12px 20px; display:flex; align-items:center; gap:10px; z-index:9999; box-shadow:0 8px 20px rgba(0,0,0,0.4); backdrop-filter:blur(8px); transform:translateX(150%); transition:transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); color:#4ade80;">
        <i class="fa-solid fa-circle-check" style="font-size:1.1rem;"></i>
        <span id="toastMessage" style="font-size:0.8rem; font-weight:600; letter-spacing:0.5px;"></span>
    </div>

    <script>
        function togglePasswordVisibility(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Check for TempData toast message
        document.addEventListener('DOMContentLoaded', () => {
            const toastMessage = '@TempData["ToastMessage"]';
            if(toastMessage) {
                const toast = document.getElementById('toastNotification');
                document.getElementById('toastMessage').textContent = toastMessage;
                toast.style.transform = 'translateX(0)';
                setTimeout(() => {
                    toast.style.transform = 'translateX(150%)';
                }, 3000);
            }
        });
    </script>
</body>
</html>