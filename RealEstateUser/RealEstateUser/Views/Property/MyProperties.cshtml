@model IEnumerable<RealEstateUser.Models.PropertyModel>

@{
    ViewData["Title"] = "My Properties";
    ViewBag.ActiveMenu = "MyProperties";
    string currentUserId = Context.Session.GetString("UserID");
}

@section Styles {
<style>
    /* ── Page layout ── */
    .myprops-page {
        padding: 3rem 0 4rem;
    }
    .myprops-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        width: calc(100% - 3rem);
    }

    /* ── Page heading ── */
    .myprops-eyebrow {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a227;
        margin-bottom: 0.4rem;
    }
    .myprops-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #ffffff;          /* pure white */
        letter-spacing: -0.5px;
        margin-bottom: 0.35rem;
    }
    .myprops-sub {
        font-size: 0.82rem;
        color: #9ca3af;          /* brighter sub-text */
        margin-bottom: 2.25rem;
    }

    /* ── Status badge ── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
    }
    .status-pending  { background: rgba(201,162,39,0.12); color: #c9a227; border: 1px solid rgba(201,162,39,0.3); }
    .status-approved { background: rgba(34,197,94,0.10);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
    .status-sold     { background: rgba(99,102,241,0.10); color: #818cf8; border: 1px solid rgba(99,102,241,0.3); }
    .status-rejected { background: rgba(239,68,68,0.10); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
    .status-default  { background: rgba(107,114,128,0.1); color: #9ca3af; border: 1px solid rgba(107,114,128,0.25); }

    /* ── Action buttons ── */
    .lx-btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        border: 1px solid rgba(201,162,39,0.35);
        color: #c9a227;
        background: transparent;
        cursor: pointer;
        transition: background 0.2s;
    }
    .lx-btn-edit:hover { background: rgba(201,162,39,0.1); }

    .lx-btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        border: 1px solid rgba(239,68,68,0.3);
        color: #f87171;
        background: transparent;
        cursor: pointer;
        transition: background 0.2s;
    }
    .lx-btn-delete:hover { background: rgba(239,68,68,0.08); }

    /* ── Edit Modal (dark theme) ── */
    .modal-content {
        background: #111318 !important;
        border: 1px solid #1f2230 !important;
        border-radius: 14px !important;
        color: #d1d5db !important;
    }
    .modal-header, .modal-footer {
        border-color: #1f2230 !important;
    }
    .modal-title { color: #f3f4f6 !important; font-weight: 600; }
    .btn-close { filter: invert(1) opacity(0.5); }
    .lx-modal-input {
        width: 100%;
        background: #0e1017;
        border: 1px solid #1f2230;
        border-radius: 8px;
        padding: 0.65rem 1rem;
        font-size: 0.83rem;
        font-family: 'Poppins', sans-serif;
        color: #e5e7eb;
        outline: none;
        transition: border-color 0.2s;
    }
    .lx-modal-input:focus { border-color: #c9a227; box-shadow: 0 0 0 2px rgba(201,162,39,0.15); }
    .lx-modal-label {
        display: block;
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 0.4rem;
    }
    .btn-modal-save {
        background: #c9a227;
        color: #0a0a0a;
        border: none;
        border-radius: 6px;
        padding: 0.55rem 1.4rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-modal-save:hover { background: #b08d1e; }
    .btn-modal-close {
        background: transparent;
        color: #6b7280;
        border: 1px solid #1f2230;
        border-radius: 6px;
        padding: 0.55rem 1.2rem;
        font-size: 0.72rem;
        font-weight: 600;
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
    }
    .btn-modal-close:hover { color: #fff; border-color: #555; }
</style>
}

<div class="myprops-page">
    <div class="myprops-inner">

        <!-- Page heading -->
        <p class="myprops-eyebrow">Your Portfolio</p>
        <h1 class="myprops-title">My Properties</h1>
        <p class="myprops-sub">Manage and track all your listed properties.</p>

        @if (ViewBag.ErrorMessage != null || TempData["ErrorMessage"] != null)
        {
            <div style="display:flex;align-items:center;gap:0.65rem;
                        background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);
                        color:#f87171;border-radius:8px;padding:0.75rem 1rem;
                        font-size:0.8rem;margin-bottom:1.5rem;">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>@(ViewBag.ErrorMessage ?? TempData["ErrorMessage"])</span>
            </div>
        }

        @{
            var boughtRented = Model.Where(p => currentUserId != p.UserID.ToString()).ToList();
            var myActiveListings = Model.Where(p => currentUserId == p.UserID.ToString() && 
                (p.Status?.ToLower() == "approved" || p.Status?.ToLower() == "available" || p.Status?.ToLower() == "sold")).ToList();
            // A rejected listing is Pending WITH a RejectionReason
            var rejectedListings = Model.Where(p => currentUserId == p.UserID.ToString() && 
                p.Status?.ToLower() == "pending" && !string.IsNullOrEmpty(p.RejectionReason)).ToList();
            // A truly pending listing is Pending WITHOUT a RejectionReason
            var pendingListings = Model.Where(p => currentUserId == p.UserID.ToString() && 
                p.Status?.ToLower() == "pending" && string.IsNullOrEmpty(p.RejectionReason)).ToList();
        }

        <!-- 1) Bought / Rented Contracts -->
        @if(boughtRented.Any())
        {
            <div style="margin-bottom: 3.5rem;">
                <h3 style="color:#fff; font-size:1.2rem; font-weight:700; margin-bottom:1.25rem;">
                    <i class="fa-solid fa-key" style="color:#c9a227; margin-right:0.5rem;"></i> My Purchases & Rentals
                </h3>
                <div class="row g-4">
                    @foreach (var property in boughtRented)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div style="background:#111318;border:1px solid #1f2230;border-radius:14px;overflow:hidden;transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s;display:flex;flex-direction:column;height:100%;" 
                                 onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 50px rgba(0,0,0,0.55)';this.style.borderColor='rgba(201,162,39,0.25)'" onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#1f2230'">
                                <div style="padding:8px 8px 0 8px;flex-shrink:0;">
                                    <div style="border-radius:10px;overflow:hidden;height:190px;position:relative;">
                                        <img src="@property.ImageUrl" alt="@property.Title" style="width:100%;height:190px;object-fit:cover;display:block;" onerror="this.src='/images/placeholder.jpg';" />
                                        <span style="position:absolute;top:10px;right:10px;background:rgba(10,10,15,0.75);backdrop-filter:blur(6px);border:1px solid rgba(201,162,39,0.35);color:#c9a227;font-size:0.55rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:0.25rem 0.6rem;border-radius:999px;">
                                            @(property.Type == "Rent" ? "Leased" : "Purchased")
                                        </span>
                                    </div>
                                </div>
                                <div style="padding:1rem 1.1rem 0.9rem;flex:1;display:flex;flex-direction:column;">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.3rem;">
                                        <h5 style="font-size:0.88rem;font-weight:600;color:#f3f4f6;margin:0;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@property.Title</h5>
                                        <span style="font-size:0.88rem;font-weight:700;color:#c9a227;white-space:nowrap;flex-shrink:0;">$@(property.Price.ToString("N0"))</span>
                                    </div>
                                    <p style="font-size:0.73rem;color:#6b7280;margin:0 0 0.6rem;"><i class="fa-solid fa-location-dot" style="color:#c9a227;font-size:0.62rem;margin-right:0.3rem;"></i>@property.Location</p>
                                    <p style="font-size:0.68rem;color:#4b5563;margin:0 0 0.6rem;">
                                        <i class="fa-regular fa-user" style="font-size:0.6rem;margin-right:0.3rem;"></i>Listed by: <span style="color:#9ca3af;">@property.CreatedBy</span>
                                    </p>
                                    <div class="mt-auto pt-2 d-flex gap-2" style="border-top:1px solid #1f2230;margin-top:0.75rem;padding-top:0.75rem;">
                                        @if (property.Type?.ToLower() == "rent")
                                        {
                                            <button class="lx-btn-delete w-100 justify-content-center" onclick="cancelLease(@property.PropertyID)">
                                                <i class="fa-solid fa-ban"></i> Cancel Lease
                                            </button>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("Index", "Sell", new { resellPropertyId = property.PropertyID })" class="lx-btn-edit w-100 justify-content-center" style="margin-bottom:0;">
                                                <i class="fa-solid fa-tags"></i> Resell
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- 2) My Active Listings (Approved/Sold) -->
        @if(myActiveListings.Any())
        {
            <div style="margin-bottom: 3.5rem;">
                <h3 style="color:#fff; font-size:1.2rem; font-weight:700; margin-bottom:1.25rem;">
                    <i class="fa-solid fa-house-circle-check" style="color:#4ade80; margin-right:0.5rem;"></i> My Active Listings
                </h3>
                <div class="row g-4">
                    @foreach (var property in myActiveListings)
                    {
                        var sc = property.Status?.ToLower() == "sold" ? "status-sold" : "status-approved";
                        <div class="col-lg-4 col-md-6">
                            <div style="background:#111318;border:1px solid #1f2230;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;height:100%;">
                                <div style="padding:8px 8px 0 8px;flex-shrink:0;">
                                    <div style="border-radius:10px;overflow:hidden;height:190px;position:relative;">
                                        <img src="@property.ImageUrl" alt="@property.Title" style="width:100%;height:190px;object-fit:cover;display:block;" onerror="this.src='/images/placeholder.jpg';" />
                                        <span class="status-badge @sc" style="position:absolute;top:10px;left:10px;backdrop-filter:blur(6px);background:rgba(10,10,15,0.75);">
                                            @(property.Status == "Available" ? "Approved" : property.Status)
                                        </span>
                                        <span style="position:absolute;top:10px;right:10px;background:rgba(10,10,15,0.75);backdrop-filter:blur(6px);border:1px solid rgba(201,162,39,0.35);color:#c9a227;font-size:0.55rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:0.25rem 0.6rem;border-radius:999px;">
                                            @(property.Type == "Rent" ? "Rent" : "Sale")
                                        </span>
                                    </div>
                                </div>
                                <div style="padding:1rem 1.1rem 0.9rem;flex:1;display:flex;flex-direction:column;">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.3rem;">
                                        <h5 style="font-size:0.88rem;font-weight:600;color:#f3f4f6;margin:0;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@property.Title</h5>
                                        <span style="font-size:0.88rem;font-weight:700;color:#c9a227;white-space:nowrap;flex-shrink:0;">$@(property.Price.ToString("N0"))</span>
                                    </div>
                                    <p style="font-size:0.73rem;color:#6b7280;margin:0 0 0.6rem;"><i class="fa-solid fa-location-dot" style="color:#c9a227;font-size:0.62rem;margin-right:0.3rem;"></i>@property.Location</p>
                                    @if (!string.IsNullOrEmpty(property.BuyerName))
                                    {
                                        <p style="font-size:0.68rem;color:#4b5563;margin:0 0 0.6rem;">
                                            <i class="fa-solid fa-handshake" style="font-size:0.6rem;margin-right:0.3rem;color:#4ade80;"></i>Purchased by: <span style="color:#4ade80;">@property.BuyerName</span>
                                        </p>
                                    }
                                    <div class="mt-auto pt-2 d-flex gap-2" style="border-top:1px solid #1f2230;margin-top:0.75rem;padding-top:0.75rem;">
                                        <a href="@Url.Action("PropertyDetail", "Home", new { id = property.PropertyID })" class="lx-btn-edit w-100 justify-content-center" style="margin-bottom:0; text-decoration:none;">
                                            <i class="fa-regular fa-eye"></i> View
                                        </a>
                                        <button class="lx-btn-delete w-100 justify-content-center" data-id="@property.PropertyID" onclick="deleteProperty(@property.PropertyID)">
                                            <i class="fa-regular fa-trash-can"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- 3) Pending Approval -->
        @if(pendingListings.Any())
        {
            <div style="margin-bottom: 3.5rem;">
                <h3 style="color:#fff; font-size:1.2rem; font-weight:700; margin-bottom:1.25rem;">
                    <i class="fa-solid fa-hourglass-half" style="color:#fbbf24; margin-right:0.5rem;"></i> Pending Approval
                </h3>
                <div class="row g-4">
                    @foreach (var property in pendingListings)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div style="background:#111318;border:1px solid #1f2230;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;height:100%;">
                                <div style="padding:8px 8px 0 8px;flex-shrink:0;">
                                    <div style="border-radius:10px;overflow:hidden;height:190px;position:relative;">
                                        <img src="@property.ImageUrl" alt="@property.Title" style="width:100%;height:190px;object-fit:cover;display:block;" onerror="this.src='/images/placeholder.jpg';" />
                                        <span class="status-badge status-pending" style="position:absolute;top:10px;left:10px;backdrop-filter:blur(6px);background:rgba(10,10,15,0.75);">PENDING</span>
                                    </div>
                                </div>
                                <div style="padding:1rem 1.1rem 0.9rem;flex:1;display:flex;flex-direction:column;">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.3rem;">
                                        <h5 style="font-size:0.88rem;font-weight:600;color:#f3f4f6;margin:0;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@property.Title</h5>
                                        <span style="font-size:0.88rem;font-weight:700;color:#c9a227;white-space:nowrap;flex-shrink:0;">$@(property.Price.ToString("N0"))</span>
                                    </div>
                                    <p style="font-size:0.75rem; color:#9ca3af; margin-bottom:0.5rem;">Waiting for Admin review.</p>
                                    <div class="mt-auto pt-2 d-flex gap-2" style="border-top:1px solid #1f2230;margin-top:0.75rem;padding-top:0.75rem;">
                                        <a href="@Url.Action("Index", "Sell", new { editPropertyId = property.PropertyID })" class="lx-btn-edit w-100 justify-content-center" style="text-decoration:none; margin-bottom:0;">
                                            <i class="fa-regular fa-pen-to-square"></i> Edit
                                        </a>
                                        <button class="lx-btn-delete w-100 justify-content-center" data-id="@property.PropertyID" onclick="deleteProperty(@property.PropertyID)">
                                            <i class="fa-regular fa-trash-can"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- 4) Rejected Listings -->
        @if(rejectedListings.Any())
        {
            <div style="margin-bottom: 3.5rem;">
                <h3 style="color:#fff; font-size:1.2rem; font-weight:700; margin-bottom:1.25rem;">
                    <i class="fa-solid fa-triangle-exclamation" style="color:#f87171; margin-right:0.5rem;"></i> Action Required (Rejected)
                </h3>
                <div class="row g-4">
                    @foreach (var property in rejectedListings)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div style="background:#111318;border:1px solid #f87171;border-radius:14px;overflow:hidden;box-shadow:0 0 15px rgba(239,68,68,0.1);display:flex;flex-direction:column;height:100%;">
                                <div style="padding:8px 8px 0 8px;flex-shrink:0;">
                                    <div style="border-radius:10px;overflow:hidden;height:190px;position:relative;">
                                        <img src="@property.ImageUrl" alt="@property.Title" style="width:100%;height:190px;object-fit:cover;display:block;" onerror="this.src='/images/placeholder.jpg';" />
                                        <span class="status-badge status-rejected" style="position:absolute;top:10px;left:10px;backdrop-filter:blur(6px);background:rgba(10,10,15,0.75);">REJECTED</span>
                                    </div>
                                </div>
                                <div style="background:rgba(239,68,68,0.1); border-bottom:1px solid rgba(239,68,68,0.3); padding:0.5rem 1rem; flex-shrink:0;">
                                    <p style="color:#f87171; font-size:0.75rem; margin:0; line-height:1.4;">
                                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                        <strong>Admin Note:</strong> @(string.IsNullOrEmpty(property.RejectionReason) ? "No reason provided." : property.RejectionReason)
                                    </p>
                                </div>
                                <div style="padding:1rem 1.1rem 0.9rem;flex:1;display:flex;flex-direction:column;">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.3rem;">
                                        <h5 style="font-size:0.88rem;font-weight:600;color:#f3f4f6;margin:0;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@property.Title</h5>
                                    </div>
                                    <div class="mt-auto pt-2 d-flex gap-2" style="border-top:1px solid #1f2230;margin-top:0.75rem;padding-top:0.75rem;">
                                        <a href="@Url.Action("Index", "Sell", new { editPropertyId = property.PropertyID })" class="lx-btn-edit w-100 justify-content-center" style="border-color:#f87171; color:#f87171; text-decoration:none; margin-bottom:0;">
                                            <i class="fa-solid fa-screwdriver-wrench"></i> Fix & Resubmit
                                        </a>
                                        <button class="lx-btn-delete w-100 justify-content-center" data-id="@property.PropertyID" onclick="deleteProperty(@property.PropertyID)">
                                            <i class="fa-regular fa-trash-can"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div style="padding:3rem;background:#111318;border:1px solid #1f2230;border-radius:14px;display:inline-block;max-width:400px;">
                    <i class="fa-solid fa-building-circle-xmark fa-3x mb-3" style="color:#c9a227;opacity:0.5;"></i>
                    <h5 style="color:#f3f4f6;font-weight:600;margin-bottom:0.5rem;">No Properties Found</h5>
                    <p style="color:#6b7280;font-size:0.82rem;margin-bottom:1.25rem;">
                        You don't have any listed, purchased, or rented properties yet.
                    </p>
                    <a asp-controller="Sell" asp-action="Index" style="display:inline-flex;align-items:center;gap:0.35rem;background:#c9a227;color:#0a0a0a;text-decoration:none;border-radius:6px;padding:0.55rem 1.4rem;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">
                        <i class="fa-solid fa-plus" style="font-size:0.65rem;"></i> List a Property
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@* Removed Modal as Edit is now handled by Sell page *@

@section Scripts {
<script>
    @* ✅ PRESERVED: all AJAX — openEditModal, editPropertyForm submit, deleteProperty *@

    @* Removed openEditModal and editPropertyForm.submit as Edit is now handled by Sell page *@

    function deleteProperty(propertyId) {
        if (confirm("Are you sure you want to delete this property?")) {
            $.ajax({
                url: '@Url.Action("DeleteProperty", "Property")' + '/' + propertyId,
                type: 'DELETE',
                success: function (response) {
                    if (response.success) { lxToast(response.message, 'success'); setTimeout(() => { location.reload(); }, 1200); }
                    else { lxToast('Failed to delete property: ' + response.message, 'error'); }
                },
                error: function () { lxToast('Error deleting property.', 'error'); }
            });
        }
    }

    function cancelLease(propertyId) {
        if (confirm("Are you sure you want to cancel your lease and return this property to the market?")) {
            $.ajax({
                url: '@Url.Action("CancelLeaseAjax", "Property")',
                type: 'POST',
                data: { propertyID: propertyId },
                success: function (response) {
                    if (response.success) { 
                        lxToast(response.message, 'success'); 
                        setTimeout(() => { location.reload(); }, 1200); 
                    } else { 
                        lxToast(response.message, 'error'); 
                    }
                },
                error: function () { lxToast('Error canceling lease.', 'error'); }
            });
        }
    }

    /* Edit Image Preview logic with clear option */
    function previewEditImage(event) {
        const input = event.target;
        const container = document.getElementById('editImagePreviewContainer');
        const preview = document.getElementById('editImagePreview');

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                container.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        } else {
            clearEditImage();
        }
    }

    function clearEditImage() {
        const input = document.getElementById('ImageUrl');
        if (input) input.value = '';
        const container = document.getElementById('editImagePreviewContainer');
        if (container) container.style.display = 'none';
        const preview = document.getElementById('editImagePreview');
        if (preview) preview.src = '';
    }
</script>
}
