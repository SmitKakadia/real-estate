@model IEnumerable<RealEstateUser.Models.PropertyModel>

@{
    ViewData["Title"] = "Favorite Properties";
    ViewBag.ActiveMenu = "SavedProperties";
}

@section Styles {
<style>
    .favs-page {
        padding: 3rem 0 4rem;
    }
    .favs-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        width: calc(100% - 3rem);
    }

    /* ── Heading ── */
    .favs-eyebrow {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a227;
        margin-bottom: 0.4rem;
    }
    .favs-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        margin-bottom: 0.35rem;
    }
    .favs-sub {
        font-size: 0.82rem;
        color: #9ca3af;
        margin-bottom: 2.25rem;
        line-height: 1.6;
    }

    /* ── Remove (un-favourite) button ── */
    .lx-unfav-btn {
        position: absolute;
        top: 18px;
        right: 18px;
        z-index: 5;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: none;
        background: rgba(10,10,15,0.82);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(6px);
        transition: transform 0.2s, background 0.2s;
    }
    .lx-unfav-btn:hover {
        transform: scale(1.15);
        background: rgba(239,68,68,0.25);
    }
    .lx-unfav-btn i { color: #c9a227; font-size: 0.75rem; }
    .lx-unfav-btn:hover i { color: #f87171; }

    @@keyframes fadeOut {
        from { opacity: 1; transform: scale(1); }
        to   { opacity: 0; transform: scale(0.95); }
    }
    .card-removing {
        animation: fadeOut 0.35s ease forwards;
        pointer-events: none;
    }
</style>
}

<div class="favs-page">
    <div class="favs-inner">

        <!-- Heading -->
        <p class="favs-eyebrow">Your Wishlist</p>
        <h1 class="favs-title">Favourite Properties</h1>
        <p class="favs-sub">Properties you've saved — click the heart to remove from favourites.</p>

        @* ✅ PRESERVED: empty state check *@
        @if (Model == null || !Model.Any())
        {
            <div style="text-align:center;padding:4rem 2rem;">
                <div style="display:inline-block;padding:3rem 2.5rem;
                            background:#111318;border:1px solid #1f2230;
                            border-radius:14px;max-width:420px;">
                    <i class="fa-regular fa-heart fa-3x mb-3"
                       style="color:#c9a227;opacity:0.5;display:block;margin-bottom:1rem;"></i>
                    <h5 style="color:#fff;font-weight:600;margin-bottom:0.5rem;">No Favourites Yet</h5>
                    <p style="color:#9ca3af;font-size:0.82rem;margin-bottom:1.5rem;line-height:1.6;">
                        Start browsing and tap the ♥ on any property to save it here.
                    </p>
                    @* ✅ PRESERVED: asp-controller="Home" asp-action="Index" *@
                    <a asp-controller="Home" asp-action="Index"
                       style="display:inline-flex;align-items:center;gap:0.35rem;
                              background:#c9a227;color:#0a0a0a;text-decoration:none;
                              border-radius:6px;padding:0.55rem 1.4rem;font-size:0.72rem;
                              font-weight:700;letter-spacing:1px;text-transform:uppercase;">
                        <i class="fa-solid fa-compass" style="font-size:0.65rem;"></i>
                        Browse Properties
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @* ✅ PRESERVED: full Model loop, PropertyModel fields, id="prop-card-@property.PropertyID" *@
                @foreach (var property in Model)
                {
                    <div class="col-lg-4 col-md-6" id="prop-card-@property.PropertyID">
                        <div style="background:#111318;border:1px solid #1f2230;border-radius:14px;
                                    overflow:hidden;transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s;
                                    display:flex;flex-direction:column;height:100%;"
                             onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 50px rgba(0,0,0,0.55)';this.style.borderColor='rgba(201,162,39,0.25)'"
                             onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#1f2230'">

                            <!-- Image (inset, same as home cards) -->
                            <div style="padding:8px 8px 0 8px;flex-shrink:0;position:relative;">
                                <div style="border-radius:10px;overflow:hidden;height:190px;">
                                    <img src="@property.ImageUrl" alt="@property.Title"
                                         style="width:100%;height:190px;object-fit:cover;display:block;
                                                transition:transform 0.5s;"
                                         onmouseover="this.style.transform='scale(1.04)'"
                                         onmouseout="this.style.transform='scale(1)'" />
                                </div>
                                <!-- Type badge -->
                                <span style="position:absolute;top:18px;left:18px;z-index:5;
                                             background:rgba(10,10,15,0.82);backdrop-filter:blur(6px);
                                             border:1px solid rgba(201,162,39,0.4);
                                             color:#c9a227;font-size:0.55rem;font-weight:700;
                                             letter-spacing:1.8px;text-transform:uppercase;
                                             padding:0.25rem 0.6rem;border-radius:999px;">
                                    @(property.Type == "Rent" ? "For Rent" : "For Sale")
                                </span>
                                @* ✅ PRESERVED: toggleFavorite(id) — same AJAX call *@
                                @* On Saved page: solid gold heart — click removes it *@
                                <button class="lx-unfav-btn"
                                        onclick="removeFavourite(event, @property.PropertyID)"
                                        title="Remove from favourites">
                                    <i class="fa-solid fa-heart"></i>
                                </button>
                            </div>

                            <!-- Card body -->
                            <div style="padding:1rem 1.1rem 0.9rem;flex:1;display:flex;flex-direction:column;">

                                <!-- Title + Price -->
                                <div style="display:flex;align-items:flex-start;justify-content:space-between;
                                            gap:0.5rem;margin-bottom:0.3rem;">
                                    <h5 style="font-size:0.88rem;font-weight:600;color:#ffffff;margin:0;
                                               flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                        title="@property.Title">
                                        @property.Title
                                    </h5>
                                    <span style="font-size:0.88rem;font-weight:700;color:#c9a227;
                                                 white-space:nowrap;flex-shrink:0;">
                                        $@(property.Price.ToString("N0"))
                                    </span>
                                </div>

                                <!-- Location -->
                                <p style="font-size:0.73rem;color:#6b7280;margin:0 0 0.6rem;">
                                    <i class="fa-solid fa-location-dot"
                                       style="color:#c9a227;font-size:0.62rem;margin-right:0.3rem;"></i>
                                    @property.Location
                                </p>

                                <!-- Status badge -->
                                <div style="margin-bottom:0.75rem;">
                                    <span style="font-size:0.58rem;font-weight:700;letter-spacing:1.2px;
                                                 text-transform:uppercase;padding:0.2rem 0.6rem;border-radius:999px;
                                                 background:rgba(107,114,128,0.12);color:#9ca3af;
                                                 border:1px solid rgba(107,114,128,0.2);">
                                        @property.Status
                                    </span>
                                </div>

                                <!-- View Details button -->
                                <div class="mt-auto">
                                    @* ✅ PRESERVED: asp-controller="Home" asp-action="PropertyDetail" asp-route-id *@
                                    <a asp-controller="Home" asp-action="PropertyDetail"
                                       asp-route-id="@property.PropertyID"
                                       style="display:flex;align-items:center;justify-content:center;gap:0.35rem;
                                              width:100%;padding:0.55rem;border-radius:8px;
                                              border:1px solid rgba(201,162,39,0.4);background:transparent;
                                              color:#c9a227;font-size:0.7rem;font-weight:600;
                                              letter-spacing:0.4px;text-decoration:none;
                                              transition:background 0.2s,border-color 0.2s;"
                                       onmouseover="this.style.background='rgba(201,162,39,0.10)';this.style.borderColor='rgba(201,162,39,0.7)'"
                                       onmouseout="this.style.background='transparent';this.style.borderColor='rgba(201,162,39,0.4)'">
                                        View Details
                                        <i class="fa-solid fa-arrow-right" style="font-size:0.58rem;"></i>
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
    @* ✅ PRESERVED: ToggleFavoriteAjax call, #prop-card-{id} jQuery fadeOut *@
    function removeFavourite(e, id) {
        if (e) e.preventDefault();
        var card = $('#prop-card-' + id);
        card.addClass('card-removing');

        $.ajax({
            url: '@Url.Action("ToggleFavoriteAjax", "Property")',
            type: 'POST',
            data: { propertyID: id },
            success: function (response) {
                if (response.success) {
                    setTimeout(function () { card.remove(); }, 350);
                } else {
                    card.removeClass('card-removing');
                    alert(response.message);
                }
            },
            error: function () {
                card.removeClass('card-removing');
                alert('Error connecting to server.');
            }
        });
    }
</script>
}
