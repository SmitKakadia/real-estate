@model RealEstateUser.Models.PropertyDto

@{
    ViewData["Title"] = "List a Property";
    ViewBag.ActiveMenu = "Sell";
}

@section Styles {
<style>
    /* ── Page layout ── */
    .sell-page {
        padding: 3rem 1.5rem 4rem;
        max-width: 820px;
        margin: 0 auto;
    }

    /* ── Page heading ── */
    .sell-eyebrow {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9a227;
        margin-bottom: 0.4rem;
    }
    .sell-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #ffffff;           /* pure white — crisp and premium */
        letter-spacing: -0.5px;
        margin-bottom: 0.35rem;
    }
    .sell-sub {
        font-size: 0.82rem;
        color: #9ca3af;           /* brighter dim text */
        margin-bottom: 2.25rem;
        line-height: 1.6;
    }

    /* ── Form card ── */
    .lx-form-card {
        background: #111318;
        border: 1px solid #1f2230;
        border-radius: 14px;
        padding: 2rem 2.25rem 2.5rem;
        box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    }

    /* ── Section divider inside card ── */
    .form-section-label {
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #c9a227;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #1f2230;
    }

    /* ── Field labels ── */
    .lx-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #9ca3af;          /* brighter than #6b7280 */
        margin-bottom: 0.45rem;
    }
    .lx-required { color: #c9a227; margin-left: 2px; }

    /* ── Inputs ── */
    .lx-input, .lx-select, .lx-textarea {
        width: 100%;
        background: #0e1017;
        border: 1px solid #1f2230;
        border-radius: 8px;
        padding: 0.72rem 1rem;
        font-size: 0.85rem;
        font-family: 'Poppins', sans-serif;
        color: #ffffff;          /* bright white input text */
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        appearance: none;
        -webkit-appearance: none;
    }
    .lx-input::placeholder,
    .lx-textarea::placeholder { color: #4b5563; }
    .lx-input:focus, .lx-select:focus, .lx-textarea:focus {
        border-color: #c9a227;
        box-shadow: 0 0 0 3px rgba(201,162,39,0.15);
    }
    .lx-select option { background: #111318; }
    .lx-textarea { resize: vertical; min-height: 110px; }

    /* Input group icon prefix */
    .lx-input-group {
        position: relative;
    }
    .lx-input-group i {
        position: absolute;
        left: 0.9rem;
        top: 50%;
        transform: translateY(-50%);
        color: #4b5563;
        font-size: 0.78rem;
        pointer-events: none;
    }
    .lx-input-group .lx-input { padding-left: 2.4rem; }

    /* ── Validation ── */
    .lx-error { font-size: 0.72rem; color: #f87171; margin-top: 0.3rem; display: block; }

    /* ── Image upload drop zone ── */
    .lx-dropzone {
        background: #0e1017;
        border: 2px dashed #1f2230;
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s;
        margin-top: 0.75rem;
        min-height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 0.5rem;
    }
    .lx-dropzone:hover { border-color: rgba(201,162,39,0.5); }
    .lx-dropzone i { color: #374151; font-size: 1.8rem; }
    .lx-dropzone span { font-size: 0.75rem; color: #4b5563; }
    #imagePreview { max-width: 100%; max-height: 360px; border-radius: 8px; display: none; }

    /* ── Submit button ── */
    .lx-submit {
        width: 100%;
        background: #c9a227;
        color: #0a0a0a;
        border: none;
        border-radius: 8px;
        padding: 0.9rem;
        font-size: 0.78rem;
        font-family: 'Poppins', sans-serif;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .lx-submit:hover {
        background: #b08d1e;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201,162,39,0.3);
    }

    /* ── Error alert ── */
    .lx-alert-error {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.25);
        color: #f87171;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        margin-bottom: 1.5rem;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .lx-form-card { animation: fadeInUp 0.5s ease-out; }
</style>
}

<div class="sell-page">

    <!-- Page heading -->
    <p class="sell-eyebrow">Premium Estate Listings</p>
    <h1 class="sell-title">
        @if (!string.IsNullOrEmpty(Model.RejectionReason)) { <text>Fix &amp; Resubmit Listing</text> }
        else if ((bool)(ViewBag.IsResell ?? false)) { <text>Resell Your Property</text> }
        else { <text>List Your Property</text> }
    </h1>
    <p class="sell-sub">
        @if (!string.IsNullOrEmpty(Model.RejectionReason)) { <text>Update your property details based on admin feedback to get it approved.</text> }
        else if ((bool)(ViewBag.IsResell ?? false)) { <text>Fill in the updated details below to list this property for resale on Lumina Luxe.</text> }
        else { <text>Fill in the details below to publish your property on the Lumina Luxe platform.</text> }
    </p>

    <!-- Form card -->
    <div class="lx-form-card">

        @* ✅ PRESERVED: ViewBag.ErrorMessage *@
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="lx-alert-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@ViewBag.ErrorMessage</span>
            </div>
        }

        @* ✅ PRESERVED: form with all original asp-action, method, enctype, asp-controller *@
        <form id="sellForm" asp-action="Index" method="post" enctype="multipart/form-data" asp-controller="Sell">

            @* ✅ PRESERVED: hidden Status field *@
            <input asp-for="Status" type="hidden" value="Pending" />
            
            @* Pass existing image URL if we are reselling *@
            <input asp-for="ExistingImageUrl" type="hidden" />
            
            @* Track old property ID for resell cleanup *@
            <input asp-for="PropertyID" type="hidden" />

            @* Container for dynamic existing-image hidden inputs — JS manages these *@
            <div id="existingImagesHiddenInputs"></div>

            <!-- ── Basic Info ──────────────────────────── -->
            <p class="form-section-label">Property Details</p>

            <div class="row g-3 mb-3">
                <div class="col-md-8">
                    <label class="lx-label">Property Title <span class="lx-required">*</span></label>
                    @* ✅ PRESERVED: asp-for="Title" *@
                    <input asp-for="Title" class="lx-input" placeholder="e.g. Luxury Villa with Pool" required />
                    <span asp-validation-for="Title" class="lx-error"></span>
                </div>
                <div class="col-md-4">
                    <label class="lx-label">Listing Type <span class="lx-required">*</span></label>
                    @* ✅ PRESERVED: asp-for="Type" *@
                    <select asp-for="Type" class="lx-select" required>
                        <option value="Sell">For Sale</option>
                        <option value="Rent">For Rent</option>
                    </select>
                    <span asp-validation-for="Type" class="lx-error"></span>
                </div>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label class="lx-label">Description <span class="lx-required">*</span></label>
                @* ✅ PRESERVED: asp-for="Description" *@
                <textarea asp-for="Description" class="lx-textarea"
                          placeholder="Detail the amazing features of this property..." required></textarea>
                <span asp-validation-for="Description" class="lx-error"></span>
            </div>

            <!-- Price + Location -->
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="lx-label">Price (USD) <span class="lx-required">*</span></label>
                    <div class="lx-input-group">
                        <i class="fa-solid fa-dollar-sign"></i>
                        @* ✅ PRESERVED: asp-for="Price" *@
                        <input asp-for="Price" type="number" step="0.01" class="lx-input"
                               placeholder="Enter amount" required />
                    </div>
                    <span asp-validation-for="Price" class="lx-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="lx-label">Address / City <span class="lx-required">*</span></label>
                    <div class="lx-input-group">
                        <i class="fa-solid fa-map-pin"></i>
                        @* ✅ PRESERVED: asp-for="Location" *@
                        <input asp-for="Location" class="lx-input"
                               placeholder="Enter physical location" required />
                    </div>
                    <span asp-validation-for="Location" class="lx-error"></span>
                </div>
            </div>

            <!-- ── Images ──────────────────────────────── -->
            <p class="form-section-label">Property Images</p>

            <!-- Cover image -->
            <div class="mb-3">
                <label class="lx-label">
                    Cover Image
                    @if (string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <span class="lx-required">*</span>
                    }
                    else
                    {
                        <span style="color:#4b5563;text-transform:none;letter-spacing:0;font-size:0.65rem;"> — leave blank to keep existing image</span>
                    }
                </label>
                @* ✅ PRESERVED: asp-for="ImageUrl", id="imageUpload", onchange="previewImage" *@
                @if (string.IsNullOrEmpty(Model.ExistingImageUrl))
                {
                    <input asp-for="ImageUrl" type="file" class="lx-input"
                           id="imageUpload" onchange="previewImage(event)"
                           accept="image/*" required />
                    <span asp-validation-for="ImageUrl" class="lx-error"></span>
                }
                else
                {
                    <input name="ImageUrl" type="file" class="lx-input"
                           id="imageUpload" onchange="previewImage(event)"
                           accept="image/*" />
                    <!-- No validation span if we already have an image -->
                }
                <!-- Preview -->
                <div class="lx-dropzone" id="dropzoneDisplay">
                    @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <img id="imagePreview" alt="Cover preview" src="@Model.ExistingImageUrl" style="display:block;" />
                        <span id="previewPlaceholder" style="display:none;">
                            <i class="fa-regular fa-image fa-2x mb-2 d-block" style="color:#374151;"></i>
                            Image preview will appear here
                        </span>
                    }
                    else
                    {
                        <img id="imagePreview" alt="Cover preview" />
                        <span id="previewPlaceholder">
                            <i class="fa-regular fa-image fa-2x mb-2 d-block" style="color:#374151;"></i>
                            Image preview will appear here
                        </span>
                    }
                </div>
            </div>

            <!-- Additional images -->
            <div class="mb-4">
                <label class="lx-label">
                    Additional Images
                    <span style="color:#4b5563;text-transform:none;letter-spacing:0;font-size:0.65rem;"> — optional, multiple allowed</span>
                </label>
                @* Use basic name attribute to avoid strict client-side validation since these are optional/handled separately when reselling *@
                <input name="AdditionalImages" type="file" class="lx-input"
                       id="additionalImagesUpload" multiple accept="image/*" onchange="previewAdditionalImages(event)" />
                
                <!-- New preview container for additional images -->
                <div id="additionalImagesPreviewContainer" style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem;"></div>
                
                @if (Model.ExistingAdditionalImages != null && Model.ExistingAdditionalImages.Count > 0)
                {
                    <!-- JS will render existing images with remove buttons -->
                    <div id="existingImagesGallery" style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px dashed #1f2230;">
                        <span style="font-size: 0.75rem; color: #9ca3af; display:block; margin-bottom: 0.5rem;">
                            <i class="fa-solid fa-images" style="color: #c9a227;"></i> Existing Gallery Images — click ✕ to remove
                        </span>
                        <div id="existingImagesContainer" style="display: flex; gap: 0.75rem; flex-wrap: wrap;"></div>
                    </div>
                    <script>
                        var existingImages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingAdditionalImages));
                    </script>
                }
                else
                {
                    <script>var existingImages = [];</script>
                }
            </div>

            <!-- Submit -->
            <button type="submit" class="lx-submit">
                @if (!string.IsNullOrEmpty(Model.RejectionReason)) { <text>Resubmit for Approval</text> }
                else if ((bool)(ViewBag.IsResell ?? false)) { <text>Apply for Resell</text> }
                else { <text>Apply for Listing</text> }
                <i class="fa-solid fa-arrow-right"></i>
            </button>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        /* Cover Image Preview logic */
        function previewImage(event) {
            const input = event.target;
            const preview = document.getElementById('imagePreview');
            const placeholder = document.getElementById('previewPlaceholder');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        }
        // ── Existing Gallery Images (removable) ──────────────────────────
        if (typeof existingImages === 'undefined') { window.existingImages = []; }

        function renderExistingImages() {
            const container = document.getElementById('existingImagesContainer');
            const hiddenContainer = document.getElementById('existingImagesHiddenInputs');
            if (!container || !hiddenContainer) return;

            container.innerHTML = '';
            hiddenContainer.innerHTML = '';

            existingImages.forEach(function(imgUrl, idx) {
                // Create hidden input
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'ExistingAdditionalImages[' + idx + ']';
                hidden.value = imgUrl;
                hidden.id = 'existingImg_' + idx;
                hiddenContainer.appendChild(hidden);

                // Create thumbnail wrapper
                const wrapper = document.createElement('div');
                wrapper.style.cssText = 'position:relative;width:80px;height:80px;border-radius:8px;overflow:visible;border:1px solid #1f2230;flex-shrink:0;';

                const img = document.createElement('img');
                img.src = imgUrl;
                img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:7px;';
                img.alt = 'Gallery image';

                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                removeBtn.title = 'Remove this image';
                removeBtn.style.cssText = 'position:absolute;top:-8px;right:-8px;background:rgba(239,68,68,0.95);color:#fff;border:2px solid #0e1017;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.65rem;z-index:10;';
                removeBtn.onclick = function() { removeExistingImage(idx); };

                wrapper.appendChild(img);
                wrapper.appendChild(removeBtn);
                container.appendChild(wrapper);
            });
        }

        function removeExistingImage(indexToRemove) {
            existingImages.splice(indexToRemove, 1);
            renderExistingImages(); // Re-render with updated array & re-indexed hidden inputs
        }

        document.addEventListener('DOMContentLoaded', function() {
            renderExistingImages();
        });
        // ──────────────────────────────────────────────────────────────────

        // Multiple images preview logic
        let additionalFiles = [];
        
        function previewAdditionalImages(event) {
            const input = event.target;
            const container = document.getElementById('additionalImagesPreviewContainer');
            
            // Empty the container and reset our array
            container.innerHTML = '';
            additionalFiles = Array.from(input.files);
            
            additionalFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const wrapper = document.createElement('div');
                    wrapper.style.position = 'relative';
                    wrapper.style.width = '100px';
                    wrapper.style.height = '100px';
                    wrapper.style.borderRadius = '8px';
                    wrapper.style.overflow = 'hidden';
                    wrapper.style.border = '1px solid #1f2230';
                    wrapper.style.flexShrink = '0';
                    
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.width = '100%';
                    img.style.height = '100%';
                    img.style.objectFit = 'cover';
                    
                    const removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                    removeBtn.style.position = 'absolute';
                    removeBtn.style.top = '4px';
                    removeBtn.style.right = '4px';
                    removeBtn.style.background = 'rgba(239,68,68,0.9)';
                    removeBtn.style.color = '#fff';
                    removeBtn.style.border = 'none';
                    removeBtn.style.borderRadius = '50%';
                    removeBtn.style.width = '24px';
                    removeBtn.style.height = '24px';
                    removeBtn.style.display = 'flex';
                    removeBtn.style.alignItems = 'center';
                    removeBtn.style.justifyContent = 'center';
                    removeBtn.style.cursor = 'pointer';
                    removeBtn.style.fontSize = '0.7rem';
                    
                    removeBtn.onclick = function() {
                        removeAdditionalImage(index);
                    };
                    
                    wrapper.appendChild(img);
                    wrapper.appendChild(removeBtn);
                    container.appendChild(wrapper);
                };
                reader.readAsDataURL(file);
            });
        }
        
        function removeAdditionalImage(indexToRemove) {
            additionalFiles.splice(indexToRemove, 1);
            
            // Update the file input using DataTransfer
            const dataTransfer = new DataTransfer();
            additionalFiles.forEach(file => dataTransfer.items.add(file));
            document.getElementById('additionalImagesUpload').files = dataTransfer.files;
            
            // Re-render previews
            document.getElementById('additionalImagesUpload').dispatchEvent(new Event('change'));
        }

        // File size validation to prevent Cloudinary crashes
        document.getElementById('sellForm').addEventListener('submit', function(e) {
            const maxFileSize = 10 * 1024 * 1024; // 10MB
            
            // Check main image
            const mainImg = document.getElementById('imageUpload');
            if (mainImg && mainImg.files.length > 0) {
                if (mainImg.files[0].size > maxFileSize) {
                    alert('The cover image is too large. Maximum allowed size is 10MB.');
                    e.preventDefault();
                    return;
                }
            }

            // Check additional images
            const addImgs = document.getElementById('additionalImagesUpload');
            if (addImgs && addImgs.files.length > 0) {
                for(let i=0; i<addImgs.files.length; i++) {
                    if(addImgs.files[i].size > maxFileSize) {
                        alert('One or more additional images are too large. Maximum allowed size per image is 10MB.');
                        e.preventDefault();
                        return;
                    }
                }
            }
        });
    </script>
}
