@model IEnumerable<RealEstateUser.Models.PropertyModel>

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
    var currentUserIdStr = Context.Session.GetString("UserID");
}

@section Styles {
    <style>
        .admin-page {
            padding: 3rem 1.5rem;
            min-height: calc(100vh - 60px);
            background: radial-gradient(circle at top right, rgba(201,162,39,0.05) 0%, transparent 40%),
                        radial-gradient(circle at bottom left, rgba(201,162,39,0.02) 0%, transparent 40%);
        }

        .admin-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .admin-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
            margin-bottom: 0.5rem;
        }

        .admin-sub {
            color: #9ca3af;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
        }

        .property-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        /* CARD STYLE - Consistent with Home/MyProperties */
        .pd-card {
            background: rgba(17, 19, 24, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .pd-card:hover {
            transform: translateY(-5px);
            border-color: rgba(201,162,39,0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 20px rgba(201,162,39,0.1);
        }

        .pd-img-wrap {
            position: relative;
            width: 100%;
            height: 180px;
            overflow: hidden;
            background: #0a0a0a;
        }

        .pd-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .pd-card:hover .pd-img {
            transform: scale(1.08);
        }

        .pd-badge-admin {
            position: absolute;
            top: 1rem;
            left: 1rem;
            background: rgba(239, 68, 68, 0.9);
            color: #fff;
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
            backdrop-filter: blur(5px);
        }

        .pd-badge-type {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(10, 12, 18, 0.85);
            color: var(--gold);
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            border: 1px solid rgba(201,162,39,0.3);
            backdrop-filter: blur(5px);
        }

        .pd-body {
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        /* Buttons matching the theme */
        .btn-approve {
            background: linear-gradient(135deg, rgba(74,222,128,0.9), rgba(22,163,74,0.9));
            color: #064e3b;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            padding: 0.75rem;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }

        .btn-approve:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(74,222,128,0.3);
        }

        .btn-reject {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 10px;
            padding: 0.75rem;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }

        .btn-reject:hover {
            background: rgba(239, 68, 68, 0.25);
            color: #fca5a5;
        }
    </style>
}

<div class="admin-page container">
    <div class="admin-header">
        <h1 class="admin-title">Admin Moderation</h1>
        <p class="admin-sub">Approve or reject pending properties before they go live on the market.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.3); color:#4ade80; padding:1rem; border-radius:12px; text-align:center; font-weight:600; margin-bottom:1.5rem;">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:#f87171; padding:1rem; border-radius:12px; text-align:center; font-weight:600; margin-bottom:1.5rem;">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="property-grid">
            @foreach (var property in Model)
            {
                <div class="pd-card">
                    <!-- Image Area -->
                    <div class="pd-img-wrap" onclick="window.location.href='@Url.Action("PropertyDetail", "Home", new { id = property.PropertyID })'" style="cursor:pointer;">
                        <img src="@property.ImageUrl" alt="@property.Title" class="pd-img" onerror="this.src='/images/placeholder.jpg';" />
                        <div class="pd-badge-type">
                            @property.Type
                        </div>
                        <div class="pd-badge-admin">
                            <i class="fa-solid fa-hourglass-half"></i> Pending Approval
                        </div>
                    </div>

                    <!-- Body Area -->
                    <div class="pd-body">
                        <!-- Title & Price row -->
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;gap:0.5rem;">
                            <h5 style="font-size:0.95rem;font-weight:700;color:#f3f4f6;margin:0;line-height:1.4;">
                                @property.Title
                            </h5>
                            <span style="font-size:1rem;font-weight:700;color:#c9a227;white-space:nowrap;flex-shrink:0;">
                                $@(property.Price.ToString("N0"))
                            </span>
                        </div>

                        <!-- Location -->
                        <p style="font-size:0.8rem;color:#9ca3af;margin:0 0 1rem;display:flex;align-items:center;gap:0.4rem;">
                            <i class="fa-solid fa-location-dot" style="color:#c9a227;font-size:0.7rem;"></i>
                            @property.Location
                        </p>

                        <!-- Seller Info -->
                        <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05); border-radius:12px; padding:0.8rem; margin-bottom:1.5rem;">
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; letter-spacing:1px; margin-bottom:0.3rem;">Seller</div>
                            <div style="font-size:0.85rem; color:#d1d5db; font-weight:600; margin-bottom:0.15rem;">
                                <i class="fa-regular fa-user me-2"></i> @property.CreatedBy
                            </div>
                            <div style="font-size:0.85rem; color:#9ca3af;">
                                <i class="fa-solid fa-phone me-2"></i> @(string.IsNullOrEmpty(property.SellerPhone) ? "No Phone Provided" : property.SellerPhone)
                            </div>
                        </div>

                        <!-- Admin Actions -->
                        <div class="mt-auto pt-3 d-flex gap-2" style="border-top:1px solid rgba(255,255,255,0.08);">
                            <form asp-action="ApproveProperty" asp-controller="Admin" method="post" class="w-100">
                                <input type="hidden" name="id" value="@property.PropertyID" />
                                <button type="submit" class="btn-approve w-100">
                                    <i class="fa-solid fa-check"></i> Approve
                                </button>
                            </form>
                            <form asp-action="RejectProperty" asp-controller="Admin" method="post" class="w-100">
                                <input type="hidden" name="id" value="@property.PropertyID" />
                                <button type="submit" class="btn-reject w-100" onclick="return confirm('Are you sure you want to reject this listing?');">
                                    <i class="fa-solid fa-xmark"></i> Reject
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align:center; padding:5rem 2rem; background:rgba(17,19,24,0.4); border:1px dashed rgba(255,255,255,0.1); border-radius:24px; max-width:600px; margin:0 auto;">
            <div style="width:80px;height:80px;background:rgba(201,162,39,0.1);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
                <i class="fa-solid fa-shield-halved fa-2x" style="color:#c9a227;"></i>
            </div>
            <h3 style="color:#fff;font-weight:700;margin-bottom:0.5rem;">All Caught Up!</h3>
            <p style="color:#9ca3af;font-size:0.95rem;margin:0;">There are no new properties pending approval. The marketplace is running smoothly.</p>
        </div>
    }
</div>
