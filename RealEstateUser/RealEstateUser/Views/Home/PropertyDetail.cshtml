@model RealEstateUser.Models.PropertyModel

@{
    ViewData["Title"] = @Model.Title;
}

@section Styles {
    <style>
        /* ── Ambient background glows (iOS glass vibe) ── */
        .pd-glow {
            position: fixed;
            width: 40vw;
            height: 40vw;
            border-radius: 50%;
            filter: blur(120px);
            z-index: 0;
            opacity: 0.15;
            pointer-events: none;
        }
        .pd-glow-1 { top: -10%; left: -10%; background: var(--gold); }
        .pd-glow-2 { bottom: -10%; right: -10%; background: #3b82f6; } /* subtle blue contrast */

        .page-wrap {
            position: relative;
            z-index: 10;
            padding: 3rem 0;
            max-width: 1240px;
            margin: 0 auto;
        }

        /* ── Header ── */
        .pd-header {
            margin-bottom: 2rem;
            padding: 0 1.5rem;
        }
        .pd-badge {
            display: inline-block;
            background: rgba(201,162,39,0.12);
            color: var(--gold);
            border: 1px solid rgba(201,162,39,0.3);
            border-radius: 999px;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 0.3rem 0.8rem;
            margin-bottom: 1rem;
        }
        .pd-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.5px;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }
        .pd-location {
            font-size: 0.95rem;
            color: #9ca3af;
        }

        /* ── Image Gallery ── */
        .pd-gallery {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
            position: relative;
            background: rgba(17, 19, 24, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15); /* top highlight */
            height: 500px;
            z-index: 10;
        }
        .pd-gallery img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            transition: transform 0.4s ease;
        }
        .pd-price-tag {
            position: absolute;
            bottom: 24px;
            right: 24px;
            background: rgba(10, 12, 18, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(201,162,39,0.4);
            color: var(--gold);
            padding: 1rem 1.75rem;
            border-radius: 12px;
            font-size: 1.8rem;
            font-weight: 700;
            box-shadow: 0 12px 30px rgba(0,0,0,0.4);
            z-index: 10;
        }
        
        /* Carousel controls */
        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            background-color: rgba(10,12,18,0.7);
            border-radius: 50%;
            background-size: 1rem;
            padding: 1.25rem;
            border: 1px solid rgba(255,255,255,0.2);
        }

        /* ── Description & Details Card ── */
        .pd-section-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .pd-section-title i { color: var(--gold); }
        .pd-desc {
            color: #d1d5db;
            line-height: 1.8;
            font-size: 0.95rem;
        }

        .pd-details-card {
            background: rgba(17, 19, 24, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15); /* top highlight */
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
            position: sticky;
            top: 80px;
            z-index: 10;
        }
        .pd-detail-item {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--card-border);
            margin-bottom: 1.25rem;
        }
        .pd-detail-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }
        .pd-detail-icon {
            width: 44px;
            height: 44px;
            background: rgba(201,162,39,0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--gold);
            flex-shrink: 0;
        }
        .pd-detail-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.2rem;
        }
        .pd-detail-val {
            font-size: 0.95rem;
            font-weight: 600;
            color: #f3f4f6;
        }

        /* ── Action Buttons ── */
        .pd-btn {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.85rem;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        .pd-btn-primary {
            background: var(--gold);
            color: #0a0a0a;
            border: none;
        }
        .pd-btn-primary:hover {
            background: var(--gold-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(201,162,39,0.3);
        }
        .pd-btn-contact {
            background: rgba(255,255,255,0.05);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.15);
        }
        .pd-btn-contact:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.3);
        }
        .pd-btn-secondary {
            background: transparent;
            color: #9ca3af;
            border: 1px solid var(--card-border);
        }
        .pd-btn-secondary:hover {
            background: rgba(255,255,255,0.03);
            color: #fff;
            border-color: #555;
        }

        /* Alerts in sidebar */
        .pd-alert {
            padding: 1rem;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 600;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        /* ── Feedback Section ── */
        .pd-feedback-wrap {
            background: rgba(17, 19, 24, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15); /* top highlight */
            border-radius: 24px;
            padding: 2.5rem;
            margin-top: 3rem;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
            position: relative;
            z-index: 10;
        }
        .pd-feedback-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.08);
            border-left: 4px solid var(--gold);
            border-radius: 10px;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }
        
        /* ── Custom Modals ── */
        .modal-content {
            background: var(--card-bg) !important;
            border: 1px solid var(--card-border) !important;
            border-radius: 16px !important;
            color: #e5e7eb !important;
        }
        .modal-header, .modal-footer { border-color: var(--card-border) !important; }
        .modal-title { color: #fff !important; font-weight: 700; }
        .btn-close { filter: invert(1) opacity(0.5); }
        
        .modal-input {
            width: 100%;
            background: #0e1017;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 0.85rem;
            color: #fff;
            outline: none;
            transition: border-color 0.2s;
        }
        .modal-input:focus { border-color: var(--gold); }
    </style>
}

<!-- Ambient glows -->
<div class="pd-glow pd-glow-1"></div>
<div class="pd-glow pd-glow-2"></div>

<div class="page-wrap container-fluid px-4 px-lg-5">

    <!-- Header -->
    <div class="pd-header">
        <span class="pd-badge">@(Model.Type == "Rent" ? "For Rent" : "For Sale")</span>
        <h1 class="pd-title">@Model.Title</h1>
        <p class="pd-location"><i class="fa-solid fa-location-dot me-2" style="color:var(--gold);"></i>@Model.Location</p>
    </div>

    <!-- Hidden field for Feedback -->
    <input type="hidden" id="hiddenPropertyID" value="@Model.PropertyID" />

    <div class="row g-5">
        
        <!-- Left Col: Images & Description -->
        <div class="col-lg-7 mb-4 mb-lg-0">
            <!-- Image Gallery -->
            <div class="pd-gallery mb-5">
                @if (Model.AdditionalImages != null && Model.AdditionalImages.Count > 0)
                {
                    <div id="propertyImagesCarousel" class="carousel slide h-100" data-bs-ride="carousel">
                        <div class="carousel-inner h-100">
                            <!-- Main Image -->
                            <div class="carousel-item active h-100">
                                <img src="@Model.ImageUrl" alt="Main Cover">
                            </div>
                            <!-- Additional Images -->
                            @foreach (var img in Model.AdditionalImages)
                            {
                                <div class="carousel-item h-100">
                                    <img src="@img" alt="Additional Property Image">
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#propertyImagesCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#propertyImagesCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                }
                else
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title">
                }
                
                <div class="pd-price-tag">
                    $@(Model.Price.ToString("N0"))
                </div>
            </div>

            <!-- Description -->
            <div>
                <h3 class="pd-section-title"><i class="fa-solid fa-align-left"></i> Property Description</h3>
                <p class="pd-desc">@Model.Description</p>
            </div>
        </div>

        <!-- Right Col: Details Card -->
        <div class="col-lg-5">
            <div class="pd-details-card">
                <h3 class="pd-section-title mb-4"><i class="fa-solid fa-circle-info"></i> Key Details</h3>
                
                <div class="pd-detail-item">
                    <div class="pd-detail-icon"><i class="fa-solid fa-map-location-dot"></i></div>
                    <div>
                        <div class="pd-detail-label">Location</div>
                        <div class="pd-detail-val">@Model.Location</div>
                    </div>
                </div>
                
                <div class="pd-detail-item">
                    <div class="pd-detail-icon"><i class="fa-solid fa-tag"></i></div>
                    <div>
                        <div class="pd-detail-label">Listing Type</div>
                        <div class="pd-detail-val" style="color:var(--gold);">@Model.Type</div>
                    </div>
                </div>

                <div class="pd-detail-item">
                    <div class="pd-detail-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <div>
                        <div class="pd-detail-label">Current Status</div>
                        @if(Model.Status.ToLower().Contains("avail")) {
                            <div class="pd-detail-val" style="color:#4ade80;">
                                <i class="fa-solid fa-check-circle me-1" style="font-size:0.8rem;"></i> @Model.Status
                            </div>
                        } else {
                            <div class="pd-detail-val" style="color:#facc15;">
                                <i class="fa-solid fa-clock me-1" style="font-size:0.8rem;"></i> @Model.Status
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex flex-column gap-3 mt-4 pt-2">
                    @{
                        var currentUserIdStr = Context.Session.GetString("UserID");
                        var currentUserRole  = Context.Session.GetString("Role");
                        bool isAdmin = currentUserRole == "Admin";
                        bool isOwner = currentUserIdStr == Model.UserID.ToString();
                        bool isSold  = Model.Status.ToLower().Contains("sold");
                    }

                    @if (isAdmin)
                    {
                        <!-- Admin sees a neutral preview banner, no buy/contact options -->
                        <div class="pd-alert" style="background:rgba(201,162,39,0.08); border:1px solid rgba(201,162,39,0.25); color:var(--gold); flex-direction:column; gap:0.4rem; text-align:center;">
                            <div><i class="fa-solid fa-shield-halved me-2"></i><strong>Admin Preview</strong></div>
                            <div style="font-size:0.75rem; color:#9ca3af; font-weight:400;">You are viewing this listing as an administrator. Transactions are not available.</div>
                        </div>
                    }
                    else if (isOwner)
                    {
                        <div class="pd-alert" style="background:rgba(201,162,39,0.1); border:1px solid rgba(201,162,39,0.3); color:var(--gold);">
                            <i class="fa-solid fa-house-user"></i> You are the owner of this property
                        </div>
                    }
                    else if (isSold)
                    {
                        <div class="pd-alert" style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:#f87171;">
                            <i class="fa-solid fa-ban"></i> This property has already been sold
                        </div>
                    }
                    else
                    {
                        <button class="pd-btn pd-btn-primary" data-bs-toggle="modal" data-bs-target="#buyModal">
                            <i class="fa-solid fa-cart-shopping"></i> Proceed to @(Model.Type.ToLower() == "rent" ? "Rent" : "Buy")
                        </button>
                        <button class="pd-btn pd-btn-contact" data-bs-toggle="modal" data-bs-target="#contactModal">
                            <i class="fa-solid fa-phone"></i> Contact Seller
                        </button>
                    }

                    <div class="d-flex gap-3">
                        <button type="button" class="pd-btn pd-btn-secondary" data-bs-toggle="modal" data-bs-target="#feedbackModal">
                            <i class="fa-regular fa-comment-dots"></i> Review
                        </button>
                        <button onclick="history.back()" class="pd-btn pd-btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Back
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Feedback Section -->
    <div class="pd-feedback-wrap">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="pd-section-title mb-0"><i class="fa-regular fa-comments"></i> Client Feedback</h3>
            <button type="button" class="pd-btn pd-btn-secondary" style="width:auto; padding:0.5rem 1.25rem; font-size:0.75rem;" id="showFeedbackBtn">
                <i class="fa-solid fa-arrows-rotate"></i> Load Reviews
            </button>
        </div>
        <div id="feedbackList">
            <div class="text-center py-5" style="color:#6b7280;">
                <i class="fa-regular fa-comments fa-2x mb-3 opacity-50"></i>
                <p class="mb-0" style="font-size:0.85rem;">Click "Load Reviews" to view what others think about this property.</p>
            </div>
        </div>
    </div>
</div>

<!-- ── Modals ── -->

<!-- Buy/Rent Confirm Modal -->
<div class="modal fade" id="buyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <form id="buyForm">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-shield-halved me-2" style="color:#4ade80;"></i> Confirm Transaction</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:0.95rem; color:#d1d5db; line-height:1.6;">You are about to initiate the @(Model.Type.ToLower() == "rent" ? "rental" : "purchase") process for <strong>@Model.Title</strong>.</p>
                    <div style="background:#0e1017; border:1px solid rgba(255,255,255,0.1); border-radius:10px; padding:1.25rem; margin-top:1.5rem; display:flex; justify-content:space-between; align-items:center;">
                        <span style="color:#9ca3af; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px; font-weight:600;">Total Price:</span>
                        <span style="color:var(--gold); font-size:1.4rem; font-weight:700;">$@(Model.Price.ToString("N0"))</span>
                    </div>
                    <input type="hidden" id="PropertyID" name="propertyID" value="@Model.PropertyID" />
                </div>
                <div class="modal-footer d-flex gap-2">
                    <button type="button" class="pd-btn pd-btn-secondary" style="width:auto; padding:0.6rem 1.2rem;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="pd-btn pd-btn-primary" style="width:auto; padding:0.6rem 1.2rem; background:#4ade80; color:#064e3b;">Confirm & Checkout</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow-lg text-center p-4">
            <div class="modal-body p-2">
                <div style="width:60px; height:60px; background:rgba(201,162,39,0.15); border-radius:50%; display:inline-flex; align-items:center; justify-content:center; margin-bottom:1.25rem; color:var(--gold);">
                    <i class="fa-solid fa-phone-volume fa-lg"></i>
                </div>
                <h4 class="mb-1 text-white" style="font-weight:700;">Seller Contact</h4>
                <p style="font-size:0.8rem; color:#9ca3af; margin-bottom:1.5rem;">Reach out to discuss details</p>
                
                <div style="background:#0e1017; border:1px solid var(--card-border); border-radius:10px; padding:1rem; margin-bottom:1.5rem;">
                    <div style="font-size:0.85rem; color:#9ca3af; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:1px; font-weight:600;">
                        <i class="fa-regular fa-user" style="margin-right:0.4rem;"></i> @Model.CreatedBy
                    </div>
                    <span style="font-size:1.1rem; font-weight:700; color:var(--gold); letter-spacing:1px; font-family:monospace;">
                        @(string.IsNullOrEmpty(Model.SellerPhone) ? "Not Available" : Model.SellerPhone)
                    </span>
                </div>

                <button type="button" class="pd-btn pd-btn-secondary" data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Feedback Modal -->
<div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <form id="feedbackForm" asp-controller="Feedback" asp-action="SubmitFeedback" method="post">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-regular fa-envelope me-2" style="color:var(--gold);"></i> Write a Review</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="PropertyID" value="@Model.PropertyID" />
                    <input type="hidden" name="UserID" id="feedbackUserID" value="@Model.UserID" />
                    <div class="mb-2">
                        <label for="Description" style="display:block; font-size:0.75rem; font-weight:600; color:#9ca3af; text-transform:uppercase; letter-spacing:1px; margin-bottom:0.5rem;">Your Feedback</label>
                        <textarea class="modal-input" id="Description" name="Description" rows="5" placeholder="Share your experience..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer d-flex gap-2">
                    <button type="button" class="pd-btn pd-btn-secondary" style="width:auto; padding:0.6rem 1.2rem;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="pd-btn pd-btn-primary" style="width:auto; padding:0.6rem 1.2rem;">Submit Review</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // BUY form submission via AJAX
        $("#buyForm").submit(function (e) {
            e.preventDefault();
            var propertyId = $("#PropertyID").val();
            $.ajax({
                url: '@Url.Action("BuyPropertyAjax", "Property")',
                type: 'POST',
                data: { propertyID: propertyId },
                success: function (response) {
                    alert(response.message);
                    window.location.href = '@Url.Action("MyProperties", "Property")';
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText || 'Error buying property.';
                    alert(errorMsg);
                    window.location.href = '@Url.Action("MyProperties", "Property")';
                }
            });
        });

        // Function to dynamically load reviews
        function loadFeedback() {
            var propertyID = $("#hiddenPropertyID").val(); 
            $("#feedbackList").html('<div class="text-center py-4"><span style="color:var(--gold);">Loading...</span></div>');
            var url = '@Url.Action("GetFeedbackByPropertyID", "Feedback")' + '/' + propertyID;
            $.ajax({
                url: url,
                type: 'GET',
                dataType: 'json', 
                success: function (feedbacks) {
                    var feedbackListHtml = '';
                    if (feedbacks && feedbacks.length > 0) {
                        feedbacks.forEach(function (feedback) {
                            feedbackListHtml += '<div class="pd-feedback-card">';
                            feedbackListHtml += '<div style="display:flex; align-items:center; margin-bottom:0.5rem;"><i class="fa-solid fa-circle-user" style="color:#6b7280; font-size:1.25rem; margin-right:0.5rem;"></i><span style="font-weight:600; color:#fff; font-size:0.9rem;">Verified User</span></div>';
                            feedbackListHtml += '<p style="margin:0; color:#d1d5db; font-size:0.9rem; line-height:1.6;">' + feedback.description + '</p>';
                            feedbackListHtml += '</div>';
                        });
                    } else {
                        feedbackListHtml = '<div class="text-center py-4" style="color:#6b7280;"><p style="font-size:0.85rem;">No feedback available yet. Be the first to review!</p></div>';
                    }
                    $("#feedbackList").html(feedbackListHtml).fadeIn();
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText || 'Error loading feedback.';
                    $("#feedbackList").html('<p style="color:#f87171; text-align:center;"><i class="fa-solid fa-triangle-exclamation me-2"></i>' + errorMsg + '</p>');
                }
            });
        }

        // FEEDBACK form submission via AJAX
        $("#feedbackForm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);
            $.ajax({
                url: '@Url.Action("SubmitFeedback", "Feedback")',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    // Hide Modal manually without refreshing
                    var modalEl = document.getElementById('feedbackModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();

                    // Clear textarea
                    $("#Description").val('');

                    alert(response);
                    
                    // Live reload feedback
                    loadFeedback();
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText || 'Error submitting feedback.';
                    alert(errorMsg);
                }
            });
        });

        $(document).ready(function() {
            // Automatically load feedback when the page opens
            loadFeedback();

            // Hook the button just in case user wants to refresh manually
            $("#showFeedbackBtn").click(function () {
                loadFeedback();
            });
        });
    </script>
}
