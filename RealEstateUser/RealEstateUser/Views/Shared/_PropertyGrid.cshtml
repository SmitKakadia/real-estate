@model IEnumerable<RealEstateUser.Models.PropertyModel>

@if (Model != null && Model.Any())
{
    @foreach (var property in Model)
    {
        var sessionUserStr = Context.Session.GetString("UserID");
        int? sessionUserID = null;
        if (int.TryParse(sessionUserStr, out int uid)) { sessionUserID = uid; }

        <div class="col-lg-4 col-md-6 prop-card-col">
            <div class="property-card h-100 d-flex flex-column"
                 style="background:#111318;border:1px solid #1f2230;
                        border-radius:14px;overflow:hidden;
                        transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s;"
                 onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 50px rgba(0,0,0,0.55)';this.style.borderColor='rgba(201,162,39,0.3)'"
                 onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#1f2230'">

                <!-- ── Image section — inset with padding to match Stitch card ── -->
                <div class="position-relative" style="flex-shrink:0;padding:8px 8px 0 8px;">

                    <a href="@Url.Action("PropertyDetail", "Home", new { id = property.PropertyID })"
                       style="display:block;border-radius:10px;overflow:hidden;height:190px;">
                        <img src="@property.ImageUrl"
                             alt="@property.Title"
                             style="width:100%;height:190px;object-fit:cover;
                                    display:block;transition:transform 0.5s;" />
                    </a>

                    <!-- Type badge — top-left over image -->
                    <span style="position:absolute;top:18px;left:18px;z-index:5;
                                 background:rgba(10,10,15,0.75);
                                 border:1px solid rgba(201,162,39,0.4);
                                 backdrop-filter:blur(6px);
                                 color:#c9a227;font-size:0.55rem;font-weight:700;
                                 letter-spacing:1.8px;text-transform:uppercase;
                                 padding:0.25rem 0.6rem;border-radius:999px;">
                        @(property.Type == "Rent" ? "For Rent" : "For Sale")
                    </span>

                    <!-- Favourite heart — top-right over image -->
                    @if (sessionUserID.HasValue && property.UserID != sessionUserID.Value)
                    {
                        var isFav = ViewBag.FavoriteIDs != null && ViewBag.FavoriteIDs.Contains(property.PropertyID.Value);
                        <button onclick="toggleFavorite(event, @property.PropertyID)"
                                style="position:absolute;top:18px;right:18px;z-index:5;
                                       width:30px;height:30px;border-radius:50%;border:none;
                                       background:rgba(10,10,15,0.75);cursor:pointer;
                                       display:flex;align-items:center;justify-content:center;
                                       backdrop-filter:blur(6px);transition:transform 0.2s;"
                                onmouseover="this.style.transform='scale(1.15)'"
                                onmouseout="this.style.transform='scale(1)'">
                            @if (isFav)
                            {
                                <i class="fa-solid fa-heart toggle-icon-@property.PropertyID"
                                   style="color:#ef4444;font-size:0.75rem;"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-heart toggle-icon-@property.PropertyID"
                                   style="color:#9ca3af;font-size:0.75rem;"></i>
                            }
                        </button>
                    }

                </div><!-- /image section -->

                <!-- ── Card body — dark panel below image ── -->
                <!-- This dark section is what the user means: the body is visible as a 
                     dark card panel under the image, NOT a transparent overlay on the image -->
                <div class="d-flex flex-column flex-fill"
                     style="padding:1rem 1.1rem 0.9rem;
                            background:#111318;
                            border-top:1px solid #1f2230;">

                    <!-- Title + Price on same row -->
                    <div style="display:flex;align-items:flex-start;
                                justify-content:space-between;gap:0.5rem;margin-bottom:0.3rem;">
                        <h5 style="font-size:0.88rem;font-weight:600;color:#f3f4f6;
                                   margin:0;line-height:1.3;flex:1;min-width:0;
                                   overflow:hidden;text-overflow:ellipsis;
                                   display:-webkit-box;-webkit-line-clamp:1;
                                   -webkit-box-orient:vertical;">
                            @property.Title
                        </h5>
                        <span style="font-size:0.88rem;font-weight:700;color:#c9a227;
                                     white-space:nowrap;flex-shrink:0;line-height:1.3;">
                            $@(property.Price.ToString("N0"))
                        </span>
                    </div>

                    <!-- Location -->
                    <p style="font-size:0.73rem;color:#6b7280;margin:0 0 0.85rem;">
                        <i class="fa-solid fa-location-dot"
                           style="color:#c9a227;font-size:0.62rem;margin-right:0.3rem;"></i>
                        @property.Location
                    </p>

                    <!-- View Details — full-width gold outlined button, flush bottom -->
                    <div class="mt-auto">
                        <a href="@Url.Action("PropertyDetail", "Home", new { id = property.PropertyID })"
                           style="display:flex;align-items:center;justify-content:center;gap:0.35rem;
                                  width:100%;padding:0.55rem;border-radius:8px;
                                  border:1px solid rgba(201,162,39,0.4);
                                  background:transparent;
                                  color:#c9a227;font-size:0.7rem;font-weight:600;
                                  letter-spacing:0.4px;text-decoration:none;
                                  transition:background 0.2s,border-color 0.2s;"
                           onmouseover="this.style.background='rgba(201,162,39,0.10)';this.style.borderColor='rgba(201,162,39,0.7)'"
                           onmouseout="this.style.background='transparent';this.style.borderColor='rgba(201,162,39,0.4)'">
                            View Details
                            <i class="fa-solid fa-arrow-right" style="font-size:0.58rem;"></i>
                        </a>
                    </div>

                </div><!-- /card body -->

            </div><!-- /property-card -->
        </div>
    }
}
else
{
    <div class="col-12 text-center py-5">
        <div style="padding:3rem;background:#111318;border:1px solid #1f2230;
                    border-radius:14px;display:inline-block;max-width:420px;margin:0 auto;">
            <i class="fa-solid fa-compass fa-3x mb-3" style="color:#c9a227;opacity:0.5;"></i>
            <h5 style="color:#f3f4f6;font-weight:600;margin-bottom:0.5rem;">No Properties Found</h5>
            <p style="color:#6b7280;font-size:0.82rem;margin-bottom:1.25rem;">
                Try adjusting your filters to find what you're looking for.
            </p>
            <button style="background:#c9a227;color:#0a0a0a;border:none;border-radius:999px;
                           padding:0.55rem 1.6rem;font-size:0.72rem;font-weight:700;
                           letter-spacing:1px;text-transform:uppercase;cursor:pointer;"
                    onclick="document.getElementById('searchForm').reset(); performSearch();">
                Clear Filters
            </button>
        </div>
    </div>
}

<style>
/* Staggered card entry animation */
@@keyframes cardEntry {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}
.prop-card-col {
    opacity: 0;
    animation: cardEntry 0.5s cubic-bezier(0.22,1,0.36,1) forwards;
    animation-delay: calc(var(--card-i, 0) * 90ms);
}
</style>

<script>
/* Assign stagger index to each card so animation-delay works */
(function() {
    document.querySelectorAll('.prop-card-col').forEach(function(el, i) {
        el.style.setProperty('--card-i', i);
    });
})();
</script>
