<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Lumina Luxe</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        /* ── Exact Stitch palette ── */
        :root {
            --bg:           #08090d;
            --surface:      #0e1017;
            --card-bg:      #111318;
            --card-border:  #1f2230;
            --input-bg:     #1a1d24;
            --input-border: #2e3240;
            --gold:         #c9a227;
            --gold-hover:   #b08d1e;
            --text:         #d1d5db;
            --text-dim:     #6b7280;
            --label:        #4b5563;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ══════════════════════════
           TOP NAVBAR  (Stitch style)
        ══════════════════════════ */
        .lx-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            height: 60px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            background: rgba(8, 9, 13, 0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--card-border);
        }

        /* Brand — left side */
        .lx-nav-brand {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: 0.3px;
            flex-shrink: 0;
        }
        .lx-nav-brand i { color: var(--gold); font-size: 0.9rem; }

        /* Nav links — absolutely centered in the navbar */
        .lx-nav-links {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        .lx-nav-links a {
            font-size: 0.8rem;
            font-weight: 500;
            color: #9ca3af;
            text-decoration: none;
            padding: 0.4rem 0.9rem;
            border-radius: 6px;
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .lx-nav-links a:hover { 
            color: var(--gold); 
            background: rgba(201,162,39,0.08); 
        }
        .lx-nav-links a.active { 
            color: var(--gold); 
            background: rgba(201,162,39,0.12); 
            font-weight: 600;
        }

        /* Auth area — pushed to right edge with margin-left:auto */
        .lx-nav-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-left: auto;
            flex-shrink: 0;
        }
        .lx-user-wrapper {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            padding: 0.35rem 0.85rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            transition: border-color 0.2s, background 0.2s;
        }
        .lx-user-wrapper:hover {
            border-color: rgba(201,162,39,0.4);
            background: rgba(201,162,39,0.05);
        }
        .lx-user-name {
            font-size: 0.78rem;
            font-weight: 600;
            color: #f3f4f6;
            letter-spacing: 0.5px;
        }
        .lx-icon-profile {
            color: var(--gold);
            font-size: 1.1rem;
        }
        .lx-btn-gold {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
            color: #0a0a0a;
            background: var(--gold);
            border: none;
            border-radius: 6px;
            padding: 0.45rem 1rem;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
        }
        .lx-btn-gold:hover {
            background: var(--gold-hover);
            color: #0a0a0a;
            transform: translateY(-1px);
        }
        .lx-btn-ghost {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: #d1d5db;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.4rem 0.85rem;
            transition: color 0.2s, background 0.2s, border-color 0.2s;
        }
        .lx-btn-ghost:hover { 
            color: #fff; 
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.25); 
        }
        .lx-btn-logout {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.4);
            border-radius: 6px;
            padding: 0.4rem 0.85rem;
            transition: color 0.2s, background 0.2s, border-color 0.2s;
        }
        .lx-btn-logout:hover { 
            background: #ef4444; 
            color: #fff; 
            border-color: #ef4444;
        }

        /* ══════════════════════
           MAIN CONTENT AREA
        ══════════════════════ */
        .lx-main {
            padding-top: 60px; /* offset for fixed nav */
            min-height: 100vh;
        }

        /* ══════════════════════
           PROPERTY CARDS (shared)
        ══════════════════════ */
        .property-card {
            background: rgba(17, 19, 24, 0.4);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 18px;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        }
        .property-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
            border-color: rgba(201,162,39,0.3);
        }
        .property-card img {
            width: 100%;
            height: 210px;
            object-fit: cover;
            transition: transform 0.5s;
        }
        .property-card:hover img { transform: scale(1.04); }
        .property-card .card-body {
            padding: 1.1rem 1.25rem 1.25rem;
            background: transparent;
        }

        /* Favorite heart */
        @@keyframes heartBurst {
            0%   { transform: scale(1); }
            50%  { transform: scale(1.5); }
            100% { transform: scale(1); }
        }
        .heart-animate { animation: heartBurst 0.3s cubic-bezier(0.175,0.885,0.32,1.275); }

        /* ══════════════════════════════════════════
           GLOBAL ANIMATION SYSTEM
        ══════════════════════════════════════════ */

        /* 1. Scroll-triggered fade + slide-up */
        @@keyframes lx-fadeUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .lx-reveal {
            opacity: 0;
        }
        .lx-reveal.lx-visible {
            animation: lx-fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }
        /* Staggered children */
        .lx-reveal-group > * {
            opacity: 0;
        }
        .lx-reveal-group.lx-visible > *:nth-child(1) { animation: lx-fadeUp 0.5s 0.05s cubic-bezier(0.22,1,0.36,1) forwards; }
        .lx-reveal-group.lx-visible > *:nth-child(2) { animation: lx-fadeUp 0.5s 0.13s cubic-bezier(0.22,1,0.36,1) forwards; }
        .lx-reveal-group.lx-visible > *:nth-child(3) { animation: lx-fadeUp 0.5s 0.21s cubic-bezier(0.22,1,0.36,1) forwards; }
        .lx-reveal-group.lx-visible > *:nth-child(4) { animation: lx-fadeUp 0.5s 0.29s cubic-bezier(0.22,1,0.36,1) forwards; }
        .lx-reveal-group.lx-visible > *:nth-child(5) { animation: lx-fadeUp 0.5s 0.37s cubic-bezier(0.22,1,0.36,1) forwards; }
        .lx-reveal-group.lx-visible > *:nth-child(n+6) { animation: lx-fadeUp 0.5s 0.45s cubic-bezier(0.22,1,0.36,1) forwards; }

        /* 2. Button ripple host */
        .lx-btn-gold, .lx-btn-ghost, .lx-btn-logout,
        .lx-submit {
            position: relative;
            overflow: hidden;
        }
        .lx-ripple {
            position: absolute;
            border-radius: 50%;
            transform: scale(0);
            animation: lx-rippleAnim 0.55s linear;
            background: rgba(255,255,255,0.25);
            pointer-events: none;
        }
        @@keyframes lx-rippleAnim {
            to { transform: scale(4); opacity: 0; }
        }

        /* 3. Input gold glow on focus */
        input:focus, textarea:focus, select:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(201,162,39,0.35) !important;
            border-color: rgba(201,162,39,0.6) !important;
            transition: box-shadow 0.2s, border-color 0.2s;
        }

        /* 4. Page-load navbar slide-down */
        @@keyframes lx-navSlide {
            from { transform: translateY(-60px); opacity: 0; }
            to   { transform: translateY(0);     opacity: 1; }
        }
        .lx-nav { animation: lx-navSlide 0.5s cubic-bezier(0.22,1,0.36,1) both; }

        /* ── Global Toast ── */
        @@keyframes lxToastIn {
            from { opacity: 0; transform: translateX(120%); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @@keyframes lxToastOut {
            from { opacity: 1; transform: translateX(0); }
            to   { opacity: 0; transform: translateX(120%); }
        }
        .lx-toast {
            position: fixed;
            top: 5rem;
            right: 1.5rem;
            z-index: 99999;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.85rem 1.4rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.3px;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: lxToastIn 0.35s cubic-bezier(0.22,1,0.36,1) forwards;
            max-width: 90vw;
            pointer-events: none;
        }
        .lx-toast.lx-toast-success {
            background: rgba(15, 28, 18, 0.92);
            border: 1px solid rgba(74,222,128,0.35);
            color: #4ade80;
        }
        .lx-toast.lx-toast-error {
            background: rgba(28, 12, 12, 0.92);
            border: 1px solid rgba(239,68,68,0.35);
            color: #f87171;
        }
        .lx-toast.lx-toast-info {
            background: rgba(12, 18, 30, 0.92);
            border: 1px solid rgba(201,162,39,0.35);
            color: #c9a227;
        }
        .lx-toast.lx-toast-out {
            animation: lxToastOut 0.3s ease forwards;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ══ NAVBAR ══ -->
    <nav class="lx-nav">
        <a asp-action="Index" asp-controller="Home" class="lx-nav-brand">
            <i class="fa-solid fa-leaf"></i> Lumina Luxe
        </a>

        @if (Context.Session.GetString("Role") != "Admin")
        {
            <div class="lx-nav-links">
                <a asp-action="Index" asp-controller="Home"
                   class="@(ViewBag.ActiveMenu == "Home" ? "active" : "")">Home</a>
                <a asp-action="Index" asp-controller="Sell"
                   class="@(ViewBag.ActiveMenu == "Sell" ? "active" : "")">Sell Property</a>
                <a asp-action="MyProperties" asp-controller="Property"
                   class="@(ViewBag.ActiveMenu == "MyProperties" ? "active" : "")">My Property</a>
                <a asp-action="SavedProperties" asp-controller="Property"
                   class="@(ViewBag.ActiveMenu == "SavedProperties" ? "active" : "")">Favorites</a>
            </div>
        }

        <div class="lx-nav-right">
            @if (Context.Session.GetString("UserID") != null)
            {
                <a href="@Url.Action("UserProfile", "User")" class="lx-user-wrapper" title="Profile">
                    <span class="lx-user-name">@Context.Session.GetString("UserName")</span>
                    <i class="fa-solid fa-circle-user lx-icon-profile"></i>
                </a>
                <a asp-controller="Auth" asp-action="Logout" class="lx-btn-logout">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
                </a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="lx-btn-ghost">Login</a>
                <a asp-controller="Auth" asp-action="Register" class="lx-btn-gold">Register</a>
            }
        </div>
    </nav>

    <!-- ══ MAIN CONTENT ══ -->
    <div class="lx-main">
        @RenderBody()
    </div>

    <!-- No legacy globalToast needed — lxToast() handles everything -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Global TempData Toast capture
        document.addEventListener('DOMContentLoaded', () => {
            const toastMessage = '@TempData["ToastMessage"]';
            if(toastMessage && toastMessage.trim() !== '') {
                lxToast(toastMessage, 'success');
            }
        });

        /* ── Global lxToast function ── */
        window.lxToast = function(msg, type) {
            // type: 'success' | 'error' | 'info'
            type = type || 'success';
            // Remove any existing toast
            document.querySelectorAll('.lx-toast').forEach(function(t) { t.remove(); });

            var iconMap = {
                success: 'fa-circle-check',
                error:   'fa-triangle-exclamation',
                info:    'fa-circle-info'
            };

            var toast = document.createElement('div');
            toast.className = 'lx-toast lx-toast-' + type;
            toast.innerHTML = '<i class="fa-solid ' + (iconMap[type] || 'fa-circle-check') + '"></i><span>' + msg + '</span>';
            document.body.appendChild(toast);

            // Auto-dismiss after 3.5s
            setTimeout(function() {
                toast.classList.add('lx-toast-out');
                setTimeout(function() { toast.remove(); }, 320);
            }, 3500);
        };

        /* ── Favourite toggle (unchanged — keep all AJAX logic) ── */
        window.toggleFavorite = function(e, id) {
            if (e) e.preventDefault();

            var icons = document.querySelectorAll('.toggle-icon-' + id);
            var texts = document.querySelectorAll('.save-btn-text-' + id);
            var isCurrentlySaved = icons.length > 0 && icons[0].classList.contains('fa-solid');
            var newStateAdded = !isCurrentlySaved;

            function applyState(isAdded) {
                icons.forEach(icon => {
                    icon.classList.remove('heart-animate');
                    void icon.offsetWidth;
                    if (isAdded) {
                        icon.classList.remove('fa-regular');
                        icon.classList.add('fa-solid', 'heart-animate');
                        icon.style.color = '#ef4444';
                    } else {
                        icon.classList.remove('fa-solid');
                        icon.classList.add('fa-regular');
                        icon.style.color = '';
                    }
                });
                texts.forEach(t => { t.innerText = isAdded ? "Saved" : "Save"; });
            }

            applyState(newStateAdded);

            $.ajax({
                url: '@Url.Action("ToggleFavoriteAjax", "Property")',
                type: 'POST',
                data: { propertyID: id },
                success: function(response) {
                    if (!response.success) {
                        applyState(isCurrentlySaved);
                        lxToast(response.message, 'error');
                    }
                },
                error: function() {
                    applyState(isCurrentlySaved);
                    lxToast('Error connecting to server.', 'error');
                }
            });
        };
    </script>

    <script>
        /* ── Global Animations JS ── */

        // 1. Scroll-triggered reveal via IntersectionObserver
        (function() {
            const targets = document.querySelectorAll('.lx-reveal, .lx-reveal-group');
            if (!targets.length) return;
            const io = new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        e.target.classList.add('lx-visible');
                        io.unobserve(e.target);
                    }
                });
            }, { threshold: 0.12 });
            targets.forEach(t => io.observe(t));
        })();

        // 2. Ripple effect on buttons
        document.addEventListener('click', function(e) {
            const btn = e.target.closest(
                '.lx-btn-gold, .lx-btn-ghost, .lx-btn-logout, .lx-submit'
            );
            if (!btn) return;
            const ripple = document.createElement('span');
            ripple.className = 'lx-ripple';
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            ripple.style.cssText = `width:${size}px;height:${size}px;left:${e.clientX - rect.left - size/2}px;top:${e.clientY - rect.top - size/2}px`;
            btn.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
