<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Lumina Luxe Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        /* ── Exact Stitch palette ── */
        :root {
            --bg:           #08090d;
            --surface:      #0e1017;
            --card-bg:      #111318;
            --card-border:  #1f2230;
            --input-bg:     #1a1d24;
            --input-border: #2e3240;
            --gold:         #c9a227;
            --gold-hover:   #b08d1e;
            --text:         #d1d5db;
            --text-dim:     #6b7280;
            --label:        #4b5563;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ══════════════════════════
           TOP NAVBAR  (Admin style)
        ══════════════════════════ */
        .lx-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            height: 60px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            background: rgba(17, 19, 24, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 2px solid rgba(201,162,39,0.5); /* Golden highlight for Admin */
        }

        /* Brand — left side */
        .lx-nav-brand {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 1.1rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: 0.5px;
            flex-shrink: 0;
        }
        .lx-nav-brand i { color: var(--gold); font-size: 1.2rem; }

        /* Nav links — absolutely centered in the navbar */
        .lx-nav-links {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .lx-nav-links a {
            font-size: 0.8rem;
            font-weight: 600;
            color: #9ca3af;
            text-decoration: none;
            padding: 0.6rem 0.9rem;
            transition: color 0.2s ease;
            white-space: nowrap;
            letter-spacing: 0.5px;
            border-bottom: 2px solid transparent;
            position: relative;
        }
        .lx-nav-links a:hover {
            color: var(--gold);
        }
        .lx-nav-links a.active { 
            color: var(--gold);
            border-bottom-color: var(--gold);
        }

        /* Auth area — pushed to right edge with margin-left:auto */
        .lx-nav-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-left: auto;
            flex-shrink: 0;
        }
        .lx-user-wrapper {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            padding: 0.4rem 1rem;
            background: rgba(201,162,39,0.1);
            border: 1px solid rgba(201,162,39,0.3);
            border-radius: 999px;
            transition: border-color 0.2s, background 0.2s;
        }
        .lx-user-wrapper:hover {
            border-color: rgba(201,162,39,0.6);
            background: rgba(201,162,39,0.15);
        }
        .lx-user-name {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--gold);
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        .lx-icon-profile {
            color: var(--gold);
            font-size: 1.1rem;
        }
        .lx-btn-logout {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.4);
            border-radius: 6px;
            padding: 0.4rem 0.85rem;
            transition: color 0.2s, background 0.2s, border-color 0.2s;
        }
        .lx-btn-logout:hover { 
            background: #ef4444; 
            color: #fff; 
            border-color: #ef4444;
        }

        /* ══════════════════════
           MAIN CONTENT AREA
        ══════════════════════ */
        .lx-main {
            padding-top: 60px; /* offset for fixed nav */
            min-height: 100vh;
        }

        /* Admin profile pill — clean link style */
        .admin-profile-wrapper .lx-user-wrapper,
        a.lx-user-wrapper {
            border: 1px solid rgba(201,162,39,0.3);
            background: rgba(201,162,39,0.08);
            border-radius: 999px;
            padding: 0.35rem 0.95rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            transition: border-color 0.2s, background 0.2s;
        }
        a.lx-user-wrapper:hover {
            border-color: rgba(201,162,39,0.6);
            background: rgba(201,162,39,0.14);
        }
        /* ── Global Toast ── */
        @@keyframes lxToastIn {
            from { opacity: 0; transform: translateX(120%); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @@keyframes lxToastOut {
            from { opacity: 1; transform: translateX(0); }
            to   { opacity: 0; transform: translateX(120%); }
        }
        .lx-toast {
            position: fixed;
            top: 5rem;
            right: 1.5rem;
            z-index: 99999;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.85rem 1.4rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.3px;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: lxToastIn 0.35s cubic-bezier(0.22,1,0.36,1) forwards;
            max-width: 90vw;
            pointer-events: none;
        }
        .lx-toast.lx-toast-success { background: rgba(15,28,18,0.92); border: 1px solid rgba(74,222,128,0.35); color: #4ade80; }
        .lx-toast.lx-toast-error   { background: rgba(28,12,12,0.92);  border: 1px solid rgba(239,68,68,0.35);  color: #f87171; }
        .lx-toast.lx-toast-info    { background: rgba(12,18,30,0.92);  border: 1px solid rgba(201,162,39,0.35); color: #c9a227; }
        .lx-toast.lx-toast-out     { animation: lxToastOut 0.3s ease forwards; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ══ ADMIN NAVBAR ══ -->
    <nav class="lx-nav">
        <div class="lx-nav-brand">
            <i class="fa-solid fa-shield-halved"></i> Lumina Luxe Admin Center
        </div>

        <div class="lx-nav-links">
            <a href="#overview" class="admin-nav-link active">Overview</a>
            <a href="#moderation" class="admin-nav-link">Approvals</a>
            <a href="#users" class="admin-nav-link">Users</a>
            <a href="#inventory" class="admin-nav-link">Inventory</a>
            <a href="#feedback" class="admin-nav-link">Feedback</a>
        </div>

        <div class="lx-nav-right">
            <a href="@Url.Action("UserProfile", "User")" class="lx-user-wrapper" title="View Profile">
                <span class="lx-user-name">@Context.Session.GetString("UserName")</span>
                <i class="fa-solid fa-user-shield lx-icon-profile"></i>
            </a>
            <a asp-controller="Auth" asp-action="Logout" class="lx-btn-logout">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
            </a>
        </div>
    </nav>

    <!-- ══ MAIN CONTENT ══ -->
    <div class="lx-main">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        /* ── Global lxToast function ── */

        window.lxToast = function(msg, type) {
            type = type || 'success';
            document.querySelectorAll('.lx-toast').forEach(function(t) { t.remove(); });
            var iconMap = { success: 'fa-circle-check', error: 'fa-triangle-exclamation', info: 'fa-circle-info' };
            var toast = document.createElement('div');
            toast.className = 'lx-toast lx-toast-' + type;
            toast.innerHTML = '<i class="fa-solid ' + (iconMap[type] || 'fa-circle-check') + '"></i><span>' + msg + '</span>';
            document.body.appendChild(toast);
            setTimeout(function() {
                toast.classList.add('lx-toast-out');
                setTimeout(function() { toast.remove(); }, 320);
            }, 3500);
        };

        // TempData Toast
        document.addEventListener('DOMContentLoaded', function() {
            var toastMessage = '@TempData["ToastMessage"]';
            if (toastMessage && toastMessage.trim() !== '') {
                lxToast(toastMessage, 'success');
            }
        });
    </script>

    <script>
        // Scroll spy — highlights the active nav link based on scroll position
        (function () {
            var sectionIds = ['overview', 'moderation', 'users', 'inventory', 'feedback'];
            var links = document.querySelectorAll('.admin-nav-link');

            function onScroll() {
                var scrollY = window.scrollY + 120;
                var atBottom = (window.innerHeight + window.scrollY) >= document.body.scrollHeight - 50;

                var active = sectionIds[0];

                if (atBottom) {
                    // When at the very bottom, always highlight the last section
                    active = sectionIds[sectionIds.length - 1];
                } else {
                    sectionIds.forEach(function (id) {
                        var el = document.getElementById(id);
                        if (el && el.offsetTop <= scrollY) active = id;
                    });
                }

                links.forEach(function (a) {
                    var href = a.getAttribute('href');
                    if (href === '#' + active) {
                        a.classList.add('active');
                    } else {
                        a.classList.remove('active');
                    }
                });
            }

            window.addEventListener('scroll', onScroll);
            onScroll(); // run once on load
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
